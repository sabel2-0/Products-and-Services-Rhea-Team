        </div>
        <div class="lb-header-right">
            <div class="lb-controls">
                <button class="lb-nav prev" type="button" aria-label="Previous">←</button>
                <button class="lb-nav next" type="button" aria-label="Next">→</button>
            </div>
        </div>
    </div>
    <div class="lb-scroll" id="leaderboardScroll">
        <div class="lb-card rank-1"><div class="lb-img-wrap"><img src="https://images.unsplash.com/photo-1551632811-561732d1e306?q=80&w=400&auto=format&fit=crop" class="lb-card-img" alt=""><div class="lb-overlay"></div><div class="lb-rank-badge">#1</div></div><div class="lb-foot"><img class="lb-avatar" src="https://i.pravatar.cc/150?img=11" alt=""><div class="lb-name">Cristiano Ronaldo</div></div></div>
        <div class="lb-card rank-2"><div class="lb-img-wrap"><img src="https://images.unsplash.com/photo-1476480862126-209bfaa8edc8?q=80&w=400&auto=format&fit=crop" class="lb-card-img" alt=""><div class="lb-overlay"></div><div class="lb-rank-badge">#2</div></div><div class="lb-foot"><img class="lb-avatar" src="https://i.pravatar.cc/150?img=32" alt=""><div class="lb-name">Alexandra Eala</div></div></div>
        <div class="lb-card rank-3"><div class="lb-img-wrap"><img src="https://images.unsplash.com/photo-1530143311094-34d807799e8f?q=80&w=400&auto=format&fit=crop" class="lb-card-img" alt=""><div class="lb-overlay"></div><div class="lb-rank-badge">#3</div></div><div class="lb-foot"><img class="lb-avatar" src="https://i.pravatar.cc/150?img=12" alt=""><div class="lb-name">Carlos Yulo</div></div></div>
        <div class="lb-card"><div class="lb-img-wrap"><img src="https://images.unsplash.com/photo-1502224562085-639556652f33?q=80&w=400&auto=format&fit=crop" class="lb-card-img" alt=""><div class="lb-overlay"></div><div class="lb-rank-badge">#4</div></div><div class="lb-foot"><img class="lb-avatar" src="https://i.pravatar.cc/150?img=15" alt=""><div class="lb-name">Manny Pacquiao</div></div></div>
        <div class="lb-card"><div class="lb-img-wrap"><img src="https://images.unsplash.com/photo-1571008887538-b36bb32f4571?q=80&w=400&auto=format&fit=crop" class="lb-card-img" alt=""><div class="lb-overlay"></div><div class="lb-rank-badge">#5</div></div><div class="lb-foot"><img class="lb-avatar" src="https://i.pravatar.cc/150?img=20" alt=""><div class="lb-name">Raquel Santos</div></div></div>
        <div class="lb-card"><div class="lb-img-wrap"><img src="https://images.unsplash.com/photo-1527525443983-6e60c75fff46?q=80&w=400&auto=format&fit=crop" class="lb-card-img" alt=""><div class="lb-overlay"></div><div class="lb-rank-badge">#6</div></div><div class="lb-foot"><img class="lb-avatar" src="https://i.pravatar.cc/150?img=25" alt=""><div class="lb-name">Marco Reyes</div></div></div>
    </div>
    <div class="lb-footer">
        <a href="/Leaderboard/LeaderboardDashboard" class="lb-view-all">View All Rankings →</a>
    </div>
</section>

<!-- POPULAR BRANDS -->
<section class="brands-section" id="brandsSection">
    <div class="brands-top">
        <div class="brands-label-group">
            <span class="brands-eyebrow">Curated Collection</span>
            <div class="brands-title-row">
                <h2 class="brands-title">POPULAR BRANDS</h2>
                <a href="/Home/Shop" class="brands-link">Shop All →</a>
            </div>
        </div>
    </div>
    <div class="brands-puzzle">
        <div class="brands-flow" id="brandsFlow"></div>
    </div>
</section>

<!-- PRE-ORDER -->
<section class="preorder-announce-section" id="preorder-announce">
    <div class="preorder-label-bar">
        <span class="preorder-eyebrow-dot"></span>
        <span class="preorder-eyebrow">Coming Soon</span>
        <span class="preorder-eyebrow-dot"></span>
    </div>
    <div id="preorder-cards-wrap" class="preorder-cards-wrap"></div>
</section>

<!-- JUST FOR YOU -->
<section class="jfy-section" id="jfySection">
    <div class="jfy-header">
        <div class="jfy-title-group">
            <span class="jfy-eyebrow">Picked For You</span>
            <h2 class="jfy-title">JUST FOR YOU</h2>
        </div>
        <a href="/Home/Shop" class="jfy-view-all">Browse All Products →</a>
    </div>
    <div class="jfy-grid" id="jfyGrid"></div>
    <div class="jfy-load-wrap">
        <button class="jfy-load-btn" id="jfyLoadMore">Load More</button>
    </div>
</section>

@section Scripts {
<script>
/* ─── Leaderboard nav ─── */
(function () {
    const s = document.getElementById('leaderboardScroll');
    if (!s) return;
    document.querySelector('.lb-nav.prev')?.addEventListener('click', () => s.scrollBy({ left: -300, behavior: 'smooth' }));
    document.querySelector('.lb-nav.next')?.addEventListener('click', () => s.scrollBy({ left:  300, behavior: 'smooth' }));
})();

/* ─── Brands ─── */
async function loadBrands() {
    let brands = [];
    try {
        const r = await fetch('/api/brands');
        if (r.ok) {
            brands = await r.json();
        } else {
            const pr = await fetch('/api/products');
            const products = await pr.json();
            const map = {};
            products.forEach(p => {
                if (p.brand) {
                    if (!map[p.brand]) map[p.brand] = { name: p.brand, count: 0 };
                    map[p.brand].count++;
                }
            });
            brands = Object.values(map);
        }
    } catch (e) { console.warn('Brands load failed:', e); }
    if (!brands.length) { document.getElementById('brandsSection').style.display = 'none'; return; }
    renderBrandRows(brands);
}

function sizeFromCount(count) {
    if (count >= 40) return 'sz-xl';
    if (count >= 25) return 'sz-lg';
    if (count >= 15) return 'sz-md';
    return 'sz-sm';
}

function renderBrandRows(brands) {
    const flow = document.getElementById('brandsFlow');
    if (!flow) return;
    const sorted = [...brands].sort((a, b) => (b.count || 0) - (a.count || 0));
    const rowSizes = [3, 4, 3, 4, 3, 4, 3];
    const rows = [];
    let i = 0, r = 0;
    while (i < sorted.length) {
        const sz = rowSizes[r % rowSizes.length];
        rows.push(sorted.slice(i, i + sz));
        i += sz; r++;
    }
    rows.forEach(row => {
        const rowEl = document.createElement('div');
        rowEl.className = 'brands-row';
        row.forEach(b => {
            const name  = typeof b === 'string' ? b : (b.name || b.brandName || '');
            const count = typeof b === 'object' ? (b.count || b.productCount || 0) : 0;
            const sz    = sizeFromCount(count);
            const card  = document.createElement('div');
            card.className = `bc ${sz}`;
            card.innerHTML = `
                <div class="bc-reveal"></div>
                <div class="bc-inner">
                    <div class="bc-text">
                        <span class="bc-name">${name}</span>
                        ${count > 0 ? `<span class="bc-count">${count} ${count === 1 ? 'item' : 'items'}</span>` : ''}
                    </div>
                    <div class="bc-arrow">↗</div>
                </div>`;
            card.addEventListener('click', () => { window.location.href = `/Home/Shop?brand=${encodeURIComponent(name)}`; });
            rowEl.appendChild(card);
        });
        flow.appendChild(rowEl);
    });
    const io = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target); } });
    }, { threshold: 0.08 });
    document.querySelectorAll('.brands-row').forEach(row => io.observe(row));
}

/* ─── Just For You ─── */
let jfyAllProducts = [];
let jfyShown = 0;
const JFY_PAGE = 10;

async function loadJustForYou() {
    try {
        const res = await fetch('/api/products');
        jfyAllProducts = await res.json();
        // Shuffle for "personalised" feel
        jfyAllProducts = jfyAllProducts.sort(() => Math.random() - 0.5);
        renderJfyCards();
        setupJfyLoadMore();
        setupJfyReveal();
    } catch (e) {
        document.getElementById('jfySection').style.display = 'none';
    }
}

function renderJfyCards() {
    const grid = document.getElementById('jfyGrid');
    if (!grid) return;
    const slice = jfyAllProducts.slice(jfyShown, jfyShown + JFY_PAGE);
    if (!slice.length) return;

    slice.forEach(p => {
        const isNew  = p.isNew || p.newArrival || false;
        const isSale = p.isOnSale || (p.originalPrice && p.originalPrice > p.price) || false;
        const badge  = isNew ? '<span class="jfy-badge new">New</span>'
                     : isSale ? '<span class="jfy-badge sale">Sale</span>' : '';
        const origPrice = isSale && (p.originalPrice || p.compareAtPrice)
            ? `<span class="jfy-price-original">${formatPeso(p.originalPrice || p.compareAtPrice)}</span>` : '';

        const card = document.createElement('div');
        card.className = 'jfy-card';
        card.innerHTML = `
            <div class="jfy-img-wrap">
                <img src="${p.image || p.imageUrl || ''}"
                     alt="${p.name}"
                     onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22533%22%3E%3Crect width=%22400%22 height=%22533%22 fill=%22%23F5F5F3%22/%3E%3C/svg%3E'">
                ${badge}
                <button class="jfy-quick-add" onclick="event.stopPropagation(); addToCart(${p.id})">Add to Cart</button>
            </div>
            <div class="jfy-info">
                <div class="jfy-brand">${p.brand || ''}</div>
                <div class="jfy-name">${p.name}</div>
                <div class="jfy-price-row">
                    <span class="jfy-price">${formatPeso(p.price)}</span>
                    ${origPrice}
                </div>
            </div>`;
        card.addEventListener('click', () => { window.location.href = `/Home/Product?id=${p.id}`; });
        grid.appendChild(card);
    });

    jfyShown += slice.length;

    // Reveal animation via IntersectionObserver
    setupJfyReveal();

    // Hide load more if all shown
    const btn = document.getElementById('jfyLoadMore');
    if (btn) btn.disabled = jfyShown >= jfyAllProducts.length;
}

function setupJfyReveal() {
    const io = new IntersectionObserver(entries => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in-view'); io.unobserve(e.target); } });
    }, { threshold: 0.08 });
    document.querySelectorAll('.jfy-card:not(.in-view)').forEach(c => io.observe(c));
}

function setupJfyLoadMore() {
    const btn = document.getElementById('jfyLoadMore');
    if (!btn) return;
    btn.addEventListener('click', () => { renderJfyCards(); });
}

function addToCart(productId) {
    fetch('/api/cart', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productId, quantity: 1 })
    }).then(() => {
        // Brief visual feedback
        const btns = document.querySelectorAll(`.jfy-card .jfy-quick-add`);
        // Could show a toast here
    }).catch(console.error);
}

/* ─── Pre-orders ─── */
async function loadPreOrders() {
    try {
        const p = await (await fetch('/api/products')).json();
        const pre = p.filter(x => x.isPreOrder);
        const w = document.getElementById('preorder-cards-wrap');
        if (!w) return;
        if (!pre.length) { document.getElementById('preorder-announce').style.display = 'none'; return; }
        w.innerHTML = pre.map(p => `
        <div class="preorder-card">
            <div class="preorder-card-image"><img src="${p.image}" alt="${p.name}"><div class="preorder-card-badge">New Release</div></div>
            <div class="preorder-card-body">
                <div class="preorder-card-tag"><span class="preorder-dot-pulse"></span>Pre-Order Now</div>
                <h2 class="preorder-card-name">${p.name}</h2>
                <p class="preorder-card-desc">${p.description}</p>
                <div class="preorder-card-meta-row">
                    <div class="preorder-card-meta-item"><span class="preorder-meta-label">Price</span><span class="preorder-meta-value">${formatPeso(p.price)}</span></div>
                    <div class="preorder-card-meta-item"><span class="preorder-meta-label">Ships</span><span class="preorder-meta-value">${p.expectedReleaseDate || 'Coming Soon'}</span></div>
                    ${p.brand ? `<div class="preorder-card-meta-item"><span class="preorder-meta-label">Brand</span><span class="preorder-meta-value">${p.brand}</span></div>` : ''}
                </div>
                <div class="preorder-card-actions">
                    <a href="/Home/Product?id=${p.id}" class="preorder-cta-btn">Pre-Order Now →</a>
                    <a href="/Home/Product?id=${p.id}" class="preorder-details-btn">View Details</a>
                </div>
            </div>
        </div>`).join('');
    } catch (e) { document.getElementById('preorder-announce').style.display = 'none'; }
}

function formatPeso(a) { return '₱' + Number(a).toLocaleString('en-PH', { minimumFractionDigits: 2 }); }

document.addEventListener('DOMContentLoaded', () => {
    loadBrands();
    loadPreOrders();
    loadJustForYou();
});
</script>
}
