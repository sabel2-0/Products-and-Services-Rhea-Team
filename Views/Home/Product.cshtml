    document.getElementById('sg-panel').classList.add('open');
    document.getElementById('sg-backdrop').classList.add('open');
    document.body.classList.add('sg-lock');
}
function closeSizeGuide() {
    document.getElementById('sg-panel').classList.remove('open');
    document.getElementById('sg-backdrop').classList.remove('open');
    document.body.classList.remove('sg-lock');
}
function sgSwitchTab(name, btn) {
    document.querySelectorAll('.sg-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.sg-tab-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    document.getElementById('sg-tab-' + name).classList.add('active');
}

let sgUnit = 'in';
const SG_CLOTHING_IN = {
    chest: ['31–33','34–36','37–39','40–42','43–45','46–48'],
    waist: ['24–26','27–29','30–32','33–35','36–38','39–42'],
    hips:  ['33–35','36–38','39–41','42–44','45–47','48–51']
};
const SG_CLOTHING_CM = {
    chest: ['79–84','86–91','94–99','102–107','109–114','117–122'],
    waist: ['61–66','69–74','76–81','84–89','91–97','99–107'],
    hips:  ['84–89','91–97','99–104','107–112','114–119','122–130']
};
const SG_FOOT_IN = ['8½','8¹¹⁄₁₆','8¹³⁄₁₆','9','9³⁄₁₆','9⁵⁄₁₆','9½'];
const SG_FOOT_CM = ['21.6','22','22.4','22.9','23.3','23.7','24.1'];

function sgSetUnit(unit) {
    sgUnit = unit;
    document.getElementById('sg-btn-in').classList.toggle('active', unit === 'in');
    document.getElementById('sg-btn-cm').classList.toggle('active', unit === 'cm');

    const clothingData = unit === 'in' ? SG_CLOTHING_IN : SG_CLOTHING_CM;
    const footData = unit === 'in' ? SG_FOOT_IN : SG_FOOT_CM;
    const unitLabel = unit === 'in' ? '(in.)' : '(cm)';

    // Update clothing table (first table in chart panel)
    const clothingRows = document.querySelectorAll('#sg-tab-chart table:first-of-type tbody tr');
    const keys = ['chest','waist','hips'];
    clothingRows.forEach((row, idx) => {
        row.querySelector('.sg-unit-label').textContent = unitLabel;
        const cells = row.querySelectorAll('td:not(.sg-row-label)');
        cells.forEach((cell, ci) => { cell.textContent = clothingData[keys[idx]][ci]; });
    });

    // Update foot length row (last row of footwear table)
    const footRows = document.querySelectorAll('#sg-tab-chart table:last-of-type tbody tr');
    const footLenRow = footRows[footRows.length - 1];
    if (footLenRow) {
        footLenRow.querySelector('.sg-unit-label').textContent = unitLabel;
        const cells = footLenRow.querySelectorAll('td:not(.sg-row-label)');
        cells.forEach((cell, ci) => { cell.textContent = footData[ci]; });
    }
}

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeSizeGuide();
});

async function loadRelated() {
    try {
        const res = await fetch('/api/products');
        const all = await res.json();
        const related = all.filter(p => p.id !== pdProduct.id && p.category === pdProduct.category).slice(0, 4);
        const grid = document.getElementById('pd-related-grid');
        if (related.length === 0) {
            grid.innerHTML = '<p class="pd-no-reviews">No related products found.</p>';
            return;
        }
        grid.innerHTML = related.map(p => `
            <div class="related-card" onclick="window.location.href='/Home/Product?id=${p.id}'">
                <div class="related-card-image">
                    <img src="${p.image}" alt="${p.name}" loading="lazy"
                        onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%27http://www.w3.org/2000/svg%27 width=%27300%27 height=%27300%27%3E%3Crect width=%27300%27 height=%27300%27 fill=%27%23fafafa%27/%3E%3C/svg%3E'">
                    <div class="related-card-overlay">View</div>
                </div>
                <div class="related-card-info">
                    <div class="related-card-name">${p.name}</div>
                    <div class="related-card-price">${formatPeso(p.price)}</div>
                </div>
            </div>
        `).join('');
    } catch(e) {}
}
