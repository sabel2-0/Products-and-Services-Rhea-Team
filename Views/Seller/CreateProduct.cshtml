@model MyAspNetApp.Models.DbProduct
@{
    ViewData["Title"] = "Manage Product Listing";
    Layout = null;
    var mode = ViewBag.Mode as string ?? "create";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON - Manage Product Listing</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --main-bg: #ffffff;
            --input-bg: #AFAFB3;
            --text-dark: #111;
            --accent-red: #c5221f;
        }

        body {
            margin: 0;
            font-family: 'Inter', sans-serif;
            background-color: var(--main-bg);
            color: var(--text-dark);
        }

        /* Top Navigation Menu */
        .top-nav {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 40px;
            border-bottom: 1px solid #eee;
        }

        .logo {
            font-weight: 800;
            font-style: italic;
            font-size: 1.4rem;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .nav-actions {
            display: flex;
            align-items: center;
            gap: 25px;
        }

        /* Main Container */
        .container {
            max-width: 900px;
            margin: 0 auto;
            padding: 40px 20px 100px 20px;
        }

        h2.page-title {
            font-size: 1.8rem;
            font-weight: 700;
            margin-bottom: 30px;
        }

        /* Image Upload Section */
        .main-upload-box {
            width: 100%;
            height: 350px;
            background-color: var(--input-bg);
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 15px;
            cursor: pointer;
            margin-bottom: 20px;
            transition: 0.2s;
        }

            .main-upload-box:hover {
                background-color: #a0a0a5;
            }

            .main-upload-box i {
                font-size: 6rem;
                color: #444;
            }

            .main-upload-box span {
                font-size: 1.4rem;
                font-weight: 600;
                color: #222;
            }

        /* Thumbnail Row with Lines & Horizontal Scroll */
        .thumbnail-row {
            display: flex;
            gap: 15px;
            margin-bottom: 40px;
            overflow-x: auto;
            padding: 10px 0; /* Padding creates space between pictures and lines */
            /* Removed the horizontal top and bottom borders as requested */
        }

            /* Sleek scrollbar styling for the thumbnail row */
            .thumbnail-row::-webkit-scrollbar {
                height: 6px;
            }

            .thumbnail-row::-webkit-scrollbar-track {
                background: transparent;
            }

            .thumbnail-row::-webkit-scrollbar-thumb {
                background: #bbb;
                border-radius: 10px;
            }

                .thumbnail-row::-webkit-scrollbar-thumb:hover {
                    background: #888;
                }

        .thumbnail {
            width: 85px;
            height: 85px;
            background-color: var(--input-bg);
            border-radius: 10px;
            flex-shrink: 0;
            position: relative;
            overflow: hidden;
            cursor: pointer;
        }

            .thumbnail img {
                width: 100%;
                height: 100%;
                object-fit: cover;
            }

        /* Delete Button on Hover */
        .delete-btn {
            position: absolute;
            top: 5px;
            right: 5px;
            background: rgba(0, 0, 0, 0.7);
            color: white;
            border: none;
            border-radius: 50%;
            width: 22px;
            height: 22px;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            cursor: pointer;
            transition: 0.2s;
        }

            .delete-btn:hover {
                background: var(--accent-red);
            }

        .thumbnail:hover .delete-btn {
            display: flex;
        }

        /* Form Details */
        h3.section-title {
            font-size: 1.4rem;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .form-row {
            margin-bottom: 15px;
        }

        .custom-input {
            width: 100%;
            background-color: var(--input-bg);
            border: none;
            padding: 20px 25px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.05rem;
            color: #222;
            box-sizing: border-box;
            outline: none;
        }

            .custom-input::placeholder {
                color: #444;
                font-weight: 400;
            }

        /* Price / Discount Flex Row */
        .split-input-box {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: var(--input-bg);
            border-radius: 12px;
            padding: 5px 25px;
        }

            .split-input-box input {
                background: transparent;
                border: none;
                font-family: 'Inter', sans-serif;
                font-size: 1.05rem;
                padding: 15px 0;
                outline: none;
                color: #222;
            }

                .split-input-box input::placeholder {
                    color: #444;
                }

        .discount-wrap {
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .discount-wrap input {
                width: 100px;
                text-align: left;
            }

        /* Variant Row (Size, Style, Qty) */
        .variant-row {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
        }

        .btn-plus-square {
            width: 55px;
            height: 55px;
            background-color: var(--input-bg);
            border: none;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.5rem;
            color: #333;
            cursor: pointer;
            flex-shrink: 0;
            overflow: hidden;
            padding: 0;
        }

            .btn-plus-square:hover {
                background-color: #a0a0a5;
            }

        .small-input {
            background-color: var(--input-bg);
            border: none;
            padding: 18px 15px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            color: #222;
            outline: none;
            flex: 1; /* Allows inputs to shrink/grow evenly */
            min-width: 70px; /* Ensures they don't get too small */
        }

            .small-input::placeholder {
                color: #444;
            }

        .availability-label {
            font-weight: 700;
            margin-left: 5px;
            margin-right: 5px;
        }

        /* Interactive Custom Checkbox Styling */
        .custom-radio {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            font-weight: 500;
            user-select: none;
            font-size: 0.9rem;
        }

            /* Hide the default checkbox */
            .custom-radio input {
                display: none;
            }

        .radio-box {
            width: 25px;
            height: 25px;
            background-color: var(--input-bg);
            border-radius: 6px;
            transition: background-color 0.2s;
        }

        /* When the hidden input is checked, turn the box black */
        .custom-radio input:checked + .radio-box {
            background-color: #000;
        }

        /* Add Size & Style Button Row */
        .add-variant-row {
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 15px;
        }

        .btn-add-variant {
            flex: 1;
            background-color: var(--input-bg);
            border: none;
            padding: 20px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.05rem;
            color: #333;
            cursor: pointer;
            text-align: center;
        }

            .btn-add-variant:hover {
                background-color: #a0a0a5;
            }

        .size-guide {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 0.85rem;
            cursor: pointer;
            width: 80px;
        }

            .size-guide i {
                font-size: 1.6rem;
                margin-top: 4px;
            }

        /* Text Area */
        textarea.custom-input {
            height: 180px;
            resize: none;
        }

        /* Action Buttons Wrapper */
        .action-buttons {
            display: flex;
            justify-content: flex-end;
            gap: 15px;
            margin-top: 20px;
        }

        /* Submit Button */
        .btn-submit {
            background-color: #1a1a1a;
            color: #fff;
            border: none;
            padding: 20px 60px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.1rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-submit:hover {
                background-color: #000;
            }

        /* Cancel Button */
        .btn-cancel {
            background-color: #fff;
            color: #111;
            border: 1px solid #111;
            padding: 20px 60px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.1rem;
            font-weight: 500;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-cancel:hover {
                background-color: #f5f5f5;
            }

        /* Image Selector Overlay Modal */
        .overlay-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.6);
            z-index: 1000;
            align-items: center;
            justify-content: center;
        }

        .overlay-content {
            background: #fff;
            padding: 30px;
            border-radius: 16px;
            max-width: 600px;
            width: 90%;
            text-align: center;
        }

            .overlay-content h3 {
                margin-top: 0;
                margin-bottom: 20px;
            }

        .grid-selector {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
            gap: 15px;
            margin-bottom: 20px;
            max-height: 400px;
            overflow-y: auto;
        }

            .grid-selector img {
                width: 100%;
                aspect-ratio: 1;
                object-fit: cover;
                border-radius: 10px;
                cursor: pointer;
                border: 2px solid transparent;
            }

                .grid-selector img:hover {
                    border-color: #111;
                }

        .close-modal {
            background: #111;
            color: #fff;
            padding: 10px 20px;
            border: none;
            border-radius: 8px;
            cursor: pointer;
        }

        /* Color Entries */
        .color-entries-section {
            margin-bottom: 20px;
        }
        .color-entry {
            background: #f5f5f5;
            border-radius: 12px;
            padding: 18px 20px;
            margin-bottom: 14px;
            position: relative;
        }
        .color-entry-header {
            display: flex;
            gap: 10px;
            align-items: center;
            margin-bottom: 12px;
        }
        .color-entry-header input {
            flex: 1;
            background-color: var(--input-bg);
            border: none;
            padding: 14px 18px;
            border-radius: 10px;
            font-family: 'Inter', sans-serif;
            font-size: 1rem;
            color: #222;
            outline: none;
        }
        .color-entry-header input::placeholder { color: #444; }
        .btn-remove-color {
            background: none;
            border: none;
            color: var(--accent-red);
            font-size: 1.3rem;
            cursor: pointer;
            padding: 8px;
            border-radius: 8px;
            transition: 0.15s;
        }
        .btn-remove-color:hover { background: rgba(197,34,31,0.08); }
        .color-photos-grid {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }
        .color-photo-thumb {
            width: 72px;
            height: 72px;
            border-radius: 10px;
            overflow: hidden;
            position: relative;
            flex-shrink: 0;
        }
        .color-photo-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .color-photo-thumb .cp-del {
            position: absolute;
            top: 3px;
            right: 3px;
            background: rgba(0,0,0,0.7);
            color: #fff;
            border: none;
            border-radius: 50%;
            width: 20px;
            height: 20px;
            display: none;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            cursor: pointer;
        }
        .color-photo-thumb:hover .cp-del { display: flex; }
        .cp-del:hover { background: var(--accent-red); }
        .color-add-photo-btn {
            width: 72px;
            height: 72px;
            border-radius: 10px;
            background: var(--input-bg);
            border: none;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            font-size: 0.7rem;
            color: #444;
            gap: 3px;
            flex-shrink: 0;
            transition: 0.15s;
        }
        .color-add-photo-btn:hover { background: #a0a0a5; }
        .color-add-photo-btn i { font-size: 1.2rem; }
        .btn-add-color {
            width: 100%;
            background-color: var(--input-bg);
            border: none;
            padding: 18px;
            border-radius: 12px;
            font-family: 'Inter', sans-serif;
            font-size: 1.05rem;
            color: #333;
            cursor: pointer;
            text-align: center;
            margin-bottom: 20px;
            transition: 0.15s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-add-color:hover { background-color: #a0a0a5; }
    </style>
</head>
<body>

    <header class="top-nav">
        <div class="logo">
            <div style="background: black; color: white; padding: 2px 10px; border-radius: 6px;">H</div>
            NEXT HORIZON
        </div>
        <div class="nav-actions">
            <i class="fa-regular fa-bell" style="font-size: 1.4rem; cursor: pointer;"></i>
            <div style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <i class="fa-regular fa-circle-user" style="font-size: 1.8rem;"></i>
                <span style="font-weight: 600;">Seller</span>
                <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem;"></i>
            </div>
        </div>
    </header>

    <div class="container">
        <h2 class="page-title" id="dynamic-page-title">
            @(mode == "edit" ? "Edit Product Listing" : mode == "renew" ? "Renew Product Listing" : mode == "relist" ? "Relist Product Listing" : "Create Product Listing")
        </h2>

        <form asp-action="CreateProduct" asp-controller="Seller" method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="mode" value="@mode" />
        <input type="hidden" asp-for="ProductId" />
        <input type="hidden" asp-for="Status" value="@(mode == "relist" ? "active" : (Model.Status ?? "active"))" />

        <input type="file" id="imageInput" name="imageFile" accept="image/*" style="display: none;">

        <div class="main-upload-box" id="uploadBox">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <span>Upload Photos</span>
        </div>

        @if (!string.IsNullOrEmpty(Model.ImagePath))
        {
        <div class="thumbnail-row" id="thumbnailRow">
            <div class="thumbnail">
                <img src="@Model.ImagePath" alt="Current image">
            </div>
        </div>
        }
        else
        {
        <div class="thumbnail-row" id="thumbnailRow">
        </div>
        }

        <h3 class="section-title">Product Details</h3>

        <div class="form-row">
            <input type="text" class="custom-input" placeholder="Product Name" asp-for="ProductName" value="@Model.ProductName">
        </div>

        <div class="form-row">
            <div class="split-input-box">
                <input type="text" placeholder="Price" asp-for="Price" value="@(Model.Price > 0 ? Model.Price.ToString("0.##") : "")">
                <div class="discount-wrap">
                    <span style="color: #444;">Discount |</span>
                    <input type="text" placeholder="" asp-for="Discount" value="@(Model.Discount.HasValue && Model.Discount.Value > 0 ? Model.Discount.Value.ToString("0.##") : "")">
                </div>
            </div>
        </div>

        <div class="form-row">
            <input type="text" class="custom-input" placeholder="Category" asp-for="Category" value="@Model.Category">
        </div>

        <div class="form-row">
            <input type="text" class="custom-input" placeholder="Brand (e.g. Nike, Adidas)" asp-for="Brand" value="@Model.Brand">
        </div>

        <div class="form-row">
            <input type="number" class="custom-input" placeholder="Quantity" asp-for="Stock" value="@(Model.Stock > 0 ? Model.Stock.ToString() : "")" min="0">
        </div>

        <div class="form-row">
            <input type="text" class="custom-input" placeholder="Sizes (comma separated, e.g. US 7, US 8, US 9, S, M, L)" asp-for="Sizes" value="@Model.Sizes">
        </div>

        <!-- Dynamic Color Entries -->
        <h3 class="section-title" style="margin-top: 25px;">Colors &amp; Variant Photos</h3>
        <div id="color-entries-container"></div>
        <button type="button" class="btn-add-color" onclick="addColorEntry()">
            <i class="fa-solid fa-plus"></i> Add Another Color
        </button>

        <div class="form-row">
            <textarea class="custom-input" placeholder="Product Details" asp-for="Details">@Model.Details</textarea>
        </div>

        <div class="action-buttons">
            <button type="button" class="btn-cancel" onclick="window.history.back()">Cancel</button>
            <button type="submit" class="btn-submit" id="dynamic-submit-btn">
                @(mode == "edit" ? "Update Product" : mode == "renew" ? "Renew Product" : mode == "relist" ? "Relist Product" : "Add Product")
            </button>
        </div>
        </form>
    </div>

    <div class="overlay-modal" id="imageModal">
        <div class="overlay-content">
            <h3>Select Variant Image</h3>
            <div class="grid-selector" id="modalGrid">
            </div>
            <button class="close-modal" onclick="document.getElementById('imageModal').style.display='none'">Close</button>
        </div>
    </div>

    <script>
        // ===== Page Mode Logic =====
        document.addEventListener('DOMContentLoaded', () => {
            const urlParams = new URLSearchParams(window.location.search);
            const mode = urlParams.get('mode');
            const pageTitle = document.getElementById('dynamic-page-title');
            const submitBtn = document.getElementById('dynamic-submit-btn');
            if (mode === 'edit') { pageTitle.innerText = 'Edit Product Listing'; submitBtn.innerText = 'Update Product'; }
            else if (mode === 'renew') { pageTitle.innerText = 'Renew Product Listing'; submitBtn.innerText = 'Renew Product'; }
            else if (mode === 'relist') { pageTitle.innerText = 'Relist Product Listing'; submitBtn.innerText = 'Relist Product'; }
            else { pageTitle.innerText = 'Create Product Listing'; submitBtn.innerText = 'Add Product'; }

            // Load existing color images for edit/relist/renew
            const existingColors = @Html.Raw(ViewBag.ExistingColorImages);
            if (existingColors && Object.keys(existingColors).length > 0) {
                for (const [colorName, paths] of Object.entries(existingColors)) {
                    addColorEntry(colorName, paths);
                }
            }
        });

        // ===== Main Image Upload =====
        const uploadBox = document.getElementById('uploadBox');
        const imageInput = document.getElementById('imageInput');
        const thumbnailRow = document.getElementById('thumbnailRow');
        let uploadedImages = [];

        uploadBox.addEventListener('click', () => imageInput.click());

        imageInput.addEventListener('change', function(event) {
            const files = event.target.files;
            for (let i = 0; i < files.length; i++) {
                const imageUrl = URL.createObjectURL(files[i]);
                uploadedImages.push(imageUrl);
                const thumbDiv = document.createElement('div');
                thumbDiv.className = 'thumbnail';
                thumbDiv.innerHTML = `
                    <img src="${imageUrl}" alt="Uploaded Photo">
                    <button class="delete-btn" onclick="removeThumbnail(this, '${imageUrl}')">
                        <i class="fa-solid fa-xmark"></i>
                    </button>`;
                thumbnailRow.appendChild(thumbDiv);
            }
        });

        window.removeThumbnail = function(button, url) {
            uploadedImages = uploadedImages.filter(img => img !== url);
            button.parentElement.remove();
        };

        // ===== Color Entries System =====
        let colorIndex = 0;
        // Per-color: { newFiles: DataTransfer, existingPaths: string[] }
        let colorData = {};

        function addColorEntry(prefilledName, prefilledPaths) {
            const idx = colorIndex++;
            colorData[idx] = { newFiles: new DataTransfer(), existingPaths: prefilledPaths ? [...prefilledPaths] : [] };

            const container = document.getElementById('color-entries-container');
            const entry = document.createElement('div');
            entry.className = 'color-entry';
            entry.id = `color-entry-${idx}`;
            entry.innerHTML = `
                <div class="color-entry-header">
                    <input type="text" name="colorNames" placeholder="Color Name (e.g. Black)" value="${prefilledName || ''}">
                    <button type="button" class="btn-remove-color" onclick="removeColorEntry(${idx})" title="Remove color">
                        <i class="fa-solid fa-trash"></i>
                    </button>
                </div>
                <input type="hidden" name="existingColorPaths_${idx}" id="existingPaths_${idx}" value="${(prefilledPaths || []).join(',')}">
                <input type="file" id="colorFileInput_${idx}" name="colorFiles_${idx}" accept="image/*" multiple style="display:none;"
                       onchange="handleColorFiles(${idx})">
                <div class="color-photos-grid" id="colorPhotos_${idx}">
                    <button type="button" class="color-add-photo-btn" onclick="document.getElementById('colorFileInput_${idx}').click()">
                        <i class="fa-solid fa-camera"></i>
                        <span>Add</span>
                    </button>
                </div>
            `;
            container.appendChild(entry);
            renderColorPhotos(idx);
        }

        function removeColorEntry(idx) {
            const el = document.getElementById(`color-entry-${idx}`);
            if (el) el.remove();
            delete colorData[idx];
        }

        function handleColorFiles(idx) {
            const input = document.getElementById(`colorFileInput_${idx}`);
            const dt = colorData[idx].newFiles;
            for (const file of input.files) {
                dt.items.add(file);
            }
            // Sync the input's files so the form submits them
            input.files = dt.files;
            renderColorPhotos(idx);
        }

        function removeNewFile(idx, fileIdx) {
            const dt = colorData[idx].newFiles;
            dt.items.remove(fileIdx);
            const input = document.getElementById(`colorFileInput_${idx}`);
            input.files = dt.files;
            renderColorPhotos(idx);
        }

        function removeExistingFile(idx, pathIdx) {
            colorData[idx].existingPaths.splice(pathIdx, 1);
            document.getElementById(`existingPaths_${idx}`).value = colorData[idx].existingPaths.join(',');
            renderColorPhotos(idx);
        }

        function renderColorPhotos(idx) {
            const grid = document.getElementById(`colorPhotos_${idx}`);
            if (!grid) return;
            let html = '';

            // Existing images
            colorData[idx].existingPaths.forEach((path, pi) => {
                html += `<div class="color-photo-thumb">
                    <img src="${path}" alt="Color photo">
                    <button type="button" class="cp-del" onclick="removeExistingFile(${idx},${pi})"><i class="fa-solid fa-xmark"></i></button>
                </div>`;
            });

            // New uploads
            const dt = colorData[idx].newFiles;
            for (let fi = 0; fi < dt.files.length; fi++) {
                const url = URL.createObjectURL(dt.files[fi]);
                html += `<div class="color-photo-thumb">
                    <img src="${url}" alt="New photo">
                    <button type="button" class="cp-del" onclick="removeNewFile(${idx},${fi})"><i class="fa-solid fa-xmark"></i></button>
                </div>`;
            }

            // Add button always at the end
            html += `<button type="button" class="color-add-photo-btn" onclick="document.getElementById('colorFileInput_${idx}').click()">
                <i class="fa-solid fa-camera"></i>
                <span>Add</span>
            </button>`;

            grid.innerHTML = html;
        }
    </script>

</body>
