@model MyAspNetApp.Models.DbProduct
@{
    ViewData["Title"] = "Manage Product Listing";
    Layout = null;
    var mode = ViewBag.Mode as string ?? "create";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON — Manage Product Listing</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/PapaParse/5.4.1/papaparse.min.js"></script>

    <link rel="stylesheet" href="~/css/CreateProduct.css" />
</head>
<body>

    <aside class="sidebar">
        <div class="logo">
            <div style="background: white; color: black; padding: 2px 10px; border-radius: 6px;">H</div>
            NEXT HORIZON
        </div>
        <nav>
            <a href="#" class="nav-item"><i class="fa-solid fa-house"></i> Dashboard</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-receipt"></i> Orders</a>
            <a href="#" class="nav-item active"><i class="fa-solid fa-bag-shopping"></i> Products</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-wallet"></i> Finances</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-chart-line"></i> Analytics</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-gear"></i> Settings</a>
        </nav>
    </aside>

    <div class="main-wrapper">

    <header class="top-nav">
        <div class="nav-left">
            <a href="#" class="logo">
                <div class="logo-mark">H</div>
                Next Horizon
            </a>
            <div class="nav-divider"></div>
            <div class="nav-breadcrumb">
                <span>Seller Portal</span>
                <i class="fa-solid fa-chevron-right" style="font-size:9px; color:var(--border-strong);"></i>
                <strong>Product Listing</strong>
            </div>
        </div>
        <div class="nav-right">
            <button class="nav-icon-btn"><i class="fa-regular fa-bell"></i></button>
            <div class="nav-user">
                <div class="nav-avatar">SE</div>
                <span>Seller</span>
                <i class="fa-solid fa-chevron-down"></i>
            </div>
        </div>
    </header>

    <div class="page-wrapper">

        <div class="page-header">
            <div class="page-header-left">
                <div class="page-eyebrow">Inventory Management</div>
                <h1 class="page-title" id="dynamic-page-title">Create Product Listing</h1>
            </div>
            <div class="page-header-actions">
                <input type="file" id="csvFileInput" accept=".csv" style="display:none;">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('csvFileInput').click()">
                    <i class="fa-solid fa-file-csv"></i> Import Variants
                </button>

                <a href="/Product/sizeguide" class="btn btn-secondary">
                    <i class="fa-solid fa-ruler-horizontal"></i> Size Guide
                </a>
            </div>
        </div>

        <form asp-action="CreateProduct" asp-controller="Seller" method="post" enctype="multipart/form-data" id="productForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="mode" value="@mode" />
            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="Status" value="@(mode == "relist" ? "active" : (Model.Status ?? "pending"))" />
            <input type="hidden" asp-for="Sizes" id="sizesHidden" />
            <input type="hidden" asp-for="Stock" id="stockHidden" />
            <input type="hidden" id="hiddenProductSku" name="SKU" value="" />
            <input type="file" id="imageInput" name="imageFile" multiple accept="image/*" style="display:none;">

            <div class="card">
                <div class="card-header">
                    <div class="card-icon"><i class="fa-regular fa-image"></i></div>
                    <div>
                        <div class="card-title">Product Media</div>
                        <div class="card-subtitle">Upload photos for this listing. First image becomes the cover.</div>
                    </div>
                </div>
                <div class="upload-zone" id="uploadBox">
                    <div class="upload-zone-icon"><i class="fa-solid fa-arrow-up-from-bracket"></i></div>
                    <div class="upload-zone-text">
                        <strong>Click to upload photos</strong>
                        <span>PNG, JPG, WEBP — up to 10MB each</span>
                    </div>
                </div>
                <div class="thumbnail-strip" id="thumbnailRow"></div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon"><i class="fa-regular fa-file-lines"></i></div>
                    <div>
                        <div class="card-title">Product Details</div>
                        <div class="card-subtitle">Core information about this product.</div>
                    </div>
                </div>

                <div class="field-group" style="margin-bottom: 10px;">
                    <div class="field">
                        <label class="field-label">Product Name</label>
                        <input type="text" class="field-input" placeholder="e.g. Classic Oxford Button-Down Shirt" asp-for="ProductName" value="@Model.ProductName">
                    </div>
                </div>

                <div class="field-group cols-2" style="margin-bottom: 10px;">
                    <div class="field">
                        <label class="field-label">Brand</label>
                        <input type="text" class="field-input" placeholder="e.g. Polo Ralph Lauren" asp-for="Brand" value="@Model.Brand">
                    </div>
                </div>

                <div class="field-group cols-2" style="margin-bottom: 10px;">
                    <div class="field">
                        <label class="field-label">Category</label>
                        <input list="category-options" class="field-input" asp-for="Category" value="@Model.Category" placeholder="Select or type a category">
                        <datalist id="category-options">
                            <option value="Tops"></option>
                            <option value="Bottoms"></option>
                            <option value="Outerwear"></option>
                            <option value="Footwear"></option>
                            <option value="Accessories"></option>
                        </datalist>
                    </div>
                    <div class="field">
                        <label class="field-label">Target Gender</label>
                        <select class="field-input" asp-for="Gender" required>
                            <option value="" disabled>Select gender</option>
                            <option value="Men">Men</option>
                            <option value="Women">Women</option>
                            <option value="Unisex">Unisex</option>
                        </select>
                    </div>
                </div>

                <div class="field">
                    <label class="field-label">Product Details</label>
                    <textarea class="field-input" placeholder="Describe the product — materials, fit, care instructions, etc." asp-for="Details" style="min-height:120px;">@Model.Details</textarea>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon"><i class="fa-solid fa-layer-group"></i></div>
                    <div>
                        <div class="card-title">Variants &amp; Inventory</div>
                        <div class="card-subtitle">Define sizes, styles, quantities and shipping dimensions per variant.</div>
                    </div>
                </div>

                <div id="variants-container"></div>

                <button type="button" class="btn-outline-dashed" id="btnAddVariant">
                    <i class="fa-solid fa-plus"></i>
                    Add Size &amp; Style Variant
                </button>
            </div>

            <div class="form-footer">
                <div class="form-footer-left">
                    All fields marked are required. <strong>Saved drafts</strong> are available in your seller dashboard.
                </div>
                <div class="form-footer-right">
                    <button type="button" class="btn btn-ghost" onclick="window.history.back()">Cancel</button>
                    <button type="submit" class="btn btn-primary" id="dynamic-submit-btn">
                        <i class="fa-solid fa-check"></i> Add Product
                    </button>
                </div>
            </div>

        </form>
    </div>

    <div class="overlay-modal" id="imageModal">
        <div class="overlay-content">
            <div class="modal-header">
                <span class="modal-title">Select Variant Images</span>
                <button type="button" class="modal-close" onclick="document.getElementById('imageModal').style.display='none'">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="grid-selector" id="modalGrid"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('imageModal').style.display='none'">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="applySelectedPhotos()">
                    <i class="fa-solid fa-check"></i> Apply Selection
                </button>
            </div>
        </div>
    </div>

    <div class="overlay-modal" id="csvModal">
        <div class="overlay-content" style="width: 800px;">
            <div class="modal-header">
                <span class="modal-title">Preview &amp; Select CSV Variants</span>
                <button type="button" class="modal-close" onclick="closeCsvModal()">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body" style="padding: 0;">
                <div class="csv-table-wrapper">
                    <table class="csv-table" id="csvTable">
                        <thead id="csvTableHeader"></thead>
                        <tbody id="csvTableBody"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <span style="flex:1; font-size:12px; color:var(--text-tertiary);" id="csvRowCount">0 rows selected</span>
                <button type="button" class="btn btn-secondary" onclick="closeCsvModal()">Cancel</button>
                <button type="button" class="btn btn-primary" onclick="applyCsvSelection()">
                    <i class="fa-solid fa-check"></i> Import Selected Rows
                </button>
            </div>
        </div>
    </div>

    <script>
        const mode = '@mode';
        const form = document.getElementById('productForm');
        const pageTitle = document.getElementById('dynamic-page-title');
        const submitBtn = document.getElementById('dynamic-submit-btn');
        const variantsContainer = document.getElementById('variants-container');
        const btnAddVariant = document.getElementById('btnAddVariant');
        const uploadBox = document.getElementById('uploadBox');
        const imageInput = document.getElementById('imageInput');
        const thumbnailRow = document.getElementById('thumbnailRow');
        const skuHidden = document.getElementById('hiddenProductSku');
        const imageModal = document.getElementById('imageModal');
        const modalGrid = document.getElementById('modalGrid');
        const existingVariants = @Html.Raw(ViewBag.ExistingVariants ?? "[]");
        let variantCount = 0;
        let selectedMainFiles = [];
        let currentVariantBtn = null;
        let currentVariantFileInput = null;
        let selectedPhotosForVariant = [];
        
        // NEW: CSV Globals
        let parsedCsvData = [];
        const csvFileInput = document.getElementById('csvFileInput');
        const csvModal = document.getElementById('csvModal');

        document.addEventListener('DOMContentLoaded', () => {
            if (mode === 'edit') {
                pageTitle.innerText = 'Edit Product Listing';
                submitBtn.innerHTML = '<i class="fa-solid fa-floppy-disk"></i> Update Product';
            } else if (mode === 'relist') {
                pageTitle.innerText = 'Relist Product Listing';
                submitBtn.innerHTML = '<i class="fa-solid fa-rotate"></i> Relist Product';
            } else if (mode === 'renew') {
                pageTitle.innerText = 'Renew Product Listing';
                submitBtn.innerHTML = '<i class="fa-solid fa-arrows-rotate"></i> Renew Product';
            }
            if (Array.isArray(existingVariants) && existingVariants.length > 0) {
                existingVariants.forEach(v => addVariantRow(v));
            } else {
                addVariantRow();
            }
        });

        // --- NEW CSV IMPORT LOGIC ---
        csvFileInput.addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (!file) return;

            Papa.parse(file, {
                header: true,
                skipEmptyLines: true,
                complete: function(results) {
                    parsedCsvData = results.data;
                    renderCsvTable(results.meta.fields, parsedCsvData);
                    csvModal.style.display = 'flex';
                    // Reset input so the same file can be uploaded again if needed
                    csvFileInput.value = ''; 
                }
            });
        });

        function renderCsvTable(headers, data) {
            const thead = document.getElementById('csvTableHeader');
            const tbody = document.getElementById('csvTableBody');
            thead.innerHTML = '';
            tbody.innerHTML = '';

            // Render Headers
            // Added a new "Main Info" column for the radio buttons
            let headerRow = '<tr><th style="width: 40px;"><input type="checkbox" id="selectAllCsv" checked onchange="toggleAllCsv(this)"></th>';
            headerRow += '<th style="width: 70px; font-size: 11px; text-align: center;">Product Details<br><span style="font-weight:normal; font-size:9px;">(Select One to fill in the Product details)</span></th>';
            headers.forEach(h => { headerRow += `<th>${h}</th>`; });
            headerRow += '</tr>';
            thead.innerHTML = headerRow;

            // Render Rows
            data.forEach((row, index) => {
                let tr = document.createElement('tr');
                
                // Add Checkbox (for variants) AND Radio Button (for Main Product Info)
                let rowHtml = `<td><input type="checkbox" class="csv-row-check" data-index="${index}" checked onchange="updateCsvCount()"></td>`;
                
                // The first row (index 0) is checked by default for the main info
                rowHtml += `<td style="text-align: center;"><input type="radio" name="mainProductRow" value="${index}" ${index === 0 ? 'checked' : ''} style="cursor:pointer; accent-color: var(--accent);"></td>`;
                
                headers.forEach(h => {
                    rowHtml += `<td>${row[h] || ''}</td>`;
                });
                tr.innerHTML = rowHtml;
                tbody.appendChild(tr);
            });
            updateCsvCount();
        }

        function toggleAllCsv(masterCheckbox) {
            const checkboxes = document.querySelectorAll('.csv-row-check');
            checkboxes.forEach(cb => cb.checked = masterCheckbox.checked);
            updateCsvCount();
        }

        function updateCsvCount() {
            const count = document.querySelectorAll('.csv-row-check:checked').length;
            document.getElementById('csvRowCount').innerText = `${count} rows selected`;
        }

        function closeCsvModal() {
            csvModal.style.display = 'none';
        }

        function applyCsvSelection() {
            // 1. FILL IN MAIN PRODUCT DETAILS FIRST
            // Find which radio button the seller selected
            const mainInfoRadio = document.querySelector('input[name="mainProductRow"]:checked');
            if (mainInfoRadio) {
                const mainRowIndex = mainInfoRadio.value;
                const mainRowData = parsedCsvData[mainRowIndex];

                // Map data to the main input fields (if the columns exist in the CSV)
                const productNameInput = document.getElementById('ProductName') || document.querySelector('input[name="ProductName"]');
                const brandInput = document.getElementById('Brand') || document.querySelector('input[name="Brand"]');
                const categoryInput = document.getElementById('Category') || document.querySelector('input[name="Category"]');
                const genderSelect = document.getElementById('Gender') || document.querySelector('select[name="Gender"]');
                const detailsInput = document.getElementById('Details') || document.querySelector('textarea[name="Details"]');

                if (productNameInput && (mainRowData['ProductName'] || mainRowData['Name'])) {
                    productNameInput.value = mainRowData['ProductName'] || mainRowData['Name'];
                }
                if (brandInput && mainRowData['Brand']) {
                    brandInput.value = mainRowData['Brand'];
                }
                if (categoryInput && mainRowData['Category']) {
                    categoryInput.value = mainRowData['Category'];
                }
                if (genderSelect && mainRowData['Gender']) {
                    // Make sure the CSV text matches "Men", "Women", or "Unisex"
                    genderSelect.value = mainRowData['Gender'];
                }
                if (detailsInput && (mainRowData['Details'] || mainRowData['Description'])) {
                    detailsInput.value = mainRowData['Details'] || mainRowData['Description'];
                }
            }

            // 2. FILL IN THE VARIANTS
            const checkboxes = document.querySelectorAll('.csv-row-check:checked');
            
            checkboxes.forEach(cb => {
                const rowIndex = cb.getAttribute('data-index');
                const rowData = parsedCsvData[rowIndex];

                // Create a variant object mapping common CSV headers to your variant keys
                const variantData = {
                    Style: rowData['Style'] || rowData['Color'] || rowData['ColorName'] || '',
                    Quantity: rowData['Quantity'] || rowData['Stock'] || rowData['Qty'] || '',
                    Size: rowData['Size'] || rowData['Sizes'] || '',
                    Price: rowData['Price'] || '',
                    SKU: rowData['SKU'] || '',
                    Weight: rowData['Weight'] || '',
                    Length: rowData['Length'] || '',
                    Height: rowData['Height'] || '',
                    Width: rowData['Width'] || '',
                    Availability: rowData['Availability'] || '' // <-- Fixed comma here!
                };

                addVariantRow(variantData);
            });

            closeCsvModal();
            computeStockAndSizes();
        }
        // --- END CSV LOGIC ---

        function generateSKU() {
            return 'SKU-' + Date.now().toString(36).toUpperCase() + '-' + Math.random().toString(36).slice(2, 6).toUpperCase();
        }

        function updateVariantBarcode(svgEl, value) {
            if (!svgEl || !value || value.trim() === '') return;
            try {
                JsBarcode(svgEl, value.trim(), {
                    format: 'CODE128',
                    lineColor: '#0F0E0C',
                    background: 'transparent',
                    width: 1.4,
                    height: 44,
                    displayValue: true,
                    fontSize: 10,
                    font: 'DM Mono, monospace',
                    margin: 0
                });
            } catch (e) {}
        }

        uploadBox.addEventListener('click', () => imageInput.click());

        function syncMainFileInput() {
            const dt = new DataTransfer();
            selectedMainFiles.forEach(f => dt.items.add(f));
            imageInput.files = dt.files;
        }

        function renderMainThumbnails() {
            thumbnailRow.innerHTML = '';
            selectedMainFiles.forEach((file, index) => {
                const url = URL.createObjectURL(file);
                const thumb = document.createElement('div');
                thumb.className = 'thumb-item';
                thumb.innerHTML = `<img src="${url}" alt=""><button class="thumb-delete" type="button"><i class="fa-solid fa-xmark"></i></button>`;
                thumb.querySelector('.thumb-delete').addEventListener('click', e => {
                    e.stopPropagation();
                    selectedMainFiles.splice(index, 1);
                    syncMainFileInput();
                    renderMainThumbnails();
                });
                thumbnailRow.appendChild(thumb);
            });
            const addBtn = document.createElement('button');
            addBtn.type = 'button';
            addBtn.className = 'thumb-add';
            addBtn.title = 'Add more photos';
            addBtn.innerHTML = '<i class="fa-solid fa-plus"></i>';
            addBtn.addEventListener('click', () => imageInput.click());
            thumbnailRow.appendChild(addBtn);

            uploadBox.style.display = selectedMainFiles.length ? 'none' : '';
        }

        imageInput.addEventListener('change', () => {
            for (const file of imageInput.files) selectedMainFiles.push(file);
            syncMainFileInput();
            renderMainThumbnails();
        });

        function isSameFile(a, b) {
            return a && b && a.name === b.name && a.size === b.size && a.lastModified === b.lastModified;
        }

        function openImageSelector(btn, fileInput) {
            currentVariantBtn = btn;
            currentVariantFileInput = fileInput;
            selectedPhotosForVariant = Array.from(fileInput.files || []);
            modalGrid.innerHTML = '';
            if (selectedMainFiles.length === 0) {
                modalGrid.innerHTML = `<div class="modal-empty" style="grid-column:1/-1;"><i class="fa-regular fa-images"></i>Upload product photos first to assign them to variants.</div>`;
            } else {
                selectedMainFiles.forEach(file => {
                    const url = URL.createObjectURL(file);
                    const wrap = document.createElement('div');
                    wrap.className = 'modal-img-container';
                    const isSelected = selectedPhotosForVariant.some(f => isSameFile(f, file));
                    if (isSelected) wrap.classList.add('selected');
                    wrap.innerHTML = `<img src="${url}" alt=""><div class="modal-check"><i class="fa-solid fa-check"></i></div>`;
                    wrap.addEventListener('click', () => {
                        const idx = selectedPhotosForVariant.findIndex(f => isSameFile(f, file));
                        if (idx > -1) { selectedPhotosForVariant.splice(idx, 1); wrap.classList.remove('selected'); }
                        else { selectedPhotosForVariant.push(file); wrap.classList.add('selected'); }
                    });
                    modalGrid.appendChild(wrap);
                });
            }
            imageModal.style.display = 'flex';
        }

        window.applySelectedPhotos = function () {
            if (!currentVariantBtn || !currentVariantFileInput) { imageModal.style.display = 'none'; return; }
            const dt = new DataTransfer();
            selectedPhotosForVariant.forEach(f => dt.items.add(f));
            currentVariantFileInput.files = dt.files;
            currentVariantBtn.innerHTML = '';

            if (selectedPhotosForVariant.length > 0) {
                selectedPhotosForVariant.slice(0, 4).forEach(file => {
                    const img = document.createElement('img');
                    img.src = URL.createObjectURL(file);
                    currentVariantBtn.appendChild(img);
                });
            } else {
                currentVariantBtn.innerHTML = '<i class="fa-solid fa-plus"></i>';
            }
            imageModal.style.display = 'none';
        };

        function renumberVariantFileInputs() {
            variantsContainer.querySelectorAll('.variant-card').forEach((card, i) => {
                const fi = card.querySelector('.hidden-color-input');
                const ep = card.querySelector('.existing-color-paths');
                if (fi) fi.name = `colorFiles_${i}`;
                if (ep) ep.name = `existingColorPaths_${i}`;
            });
        }

        function addVariantRow(variant) {
            const idx = variantCount;
            const groupName = `availability-${idx}`;
            const card = document.createElement('div');
            card.className = 'variant-card';
            card.dataset.idx = idx;
            card.innerHTML = `
                <div class="variant-card-header">
                    <span class="variant-number">Variant ${idx + 1}</span>
                    <button type="button" class="variant-remove-btn" title="Remove variant">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                </div>

                <div class="variant-grid">
                    <button type="button" class="variant-img-upload" title="Assign photos">
                        <i class="fa-solid fa-plus"></i>
                    </button>
                    <input type="file" class="hidden-color-input" multiple accept="image/*" style="display:none;">
                    <input type="hidden" class="existing-color-paths" value="">

                    <div class="field">
                        <label class="field-label">SKU</label>
                        <div class="prefixed-input">
                            <input type="text" class="sku-display" name="variantSkus">
                        </div>
                    </div>
                    <div class="field">
                        <label class="field-label">Price</label>
                        <div class="prefixed-input">
                            <span class="price-prefix">₱</span>
                            <input type="number" class="field-input" name="variantPrices" placeholder="0.00" min="0" step="any">
                        </div>
                    </div>
                    <div class="field">
                        <label class="field-label">Size (one per variant)</label>
                        <input type="text" class="field-input" name="colorSizes" placeholder="e.g. M">
                    </div>
                    <div class="field">
                        <label class="field-label">Style / Color</label>
                        <input type="text" class="field-input" name="colorNames" placeholder="e.g. Navy Blue">
                    </div>
                    <div class="field">
                        <label class="field-label">Quantity</label>
                        <input type="number" class="field-input qty-input" name="colorStocks" placeholder="0" min="0">
                    </div>
                </div>

                <div class="variant-dims">
                    <div class="field">
                        <label class="field-label">Weight</label>
                        <div class="prefixed-input">
                            <input type="number" class="field-input" name="variantWeights" placeholder="0" min="0" step="any">
                            <select class="unit-select"><option>kg</option><option>lb</option><option>g</option></select>
                        </div>
                    </div>
                    <div class="field">
                        <label class="field-label">Length</label>
                        <div class="prefixed-input">
                            <input type="number" class="field-input" name="variantLengths" placeholder="0" min="0" step="any">
                            <select class="unit-select"><option>in</option><option>cm</option></select>
                        </div>
                    </div>
                    <div class="field">
                        <label class="field-label">Height</label>
                        <div class="prefixed-input">
                            <input type="number" class="field-input" name="variantHeights" placeholder="0" min="0" step="any">
                            <select class="unit-select"><option>in</option><option>cm</option></select>
                        </div>
                    </div>
                    <div class="field">
                        <label class="field-label">Width</label>
                        <div class="prefixed-input">
                            <input type="number" class="field-input" name="variantWidths" placeholder="0" min="0" step="any">
                            <select class="unit-select"><option>in</option><option>cm</option></select>
                        </div>
                    </div>
                </div>

                <div class="variant-availability">
                    <span class="avail-label">Availability</span>
                    <div class="radio-toggle">
                        <label>
                            <input type="radio" name="${groupName}" value="In Stock" checked>
                            <span><span class="radio-dot"></span> In Stock</span>
                        </label>
                        <label>
                            <input type="radio" name="${groupName}" value="Pre-Order">
                            <span><span class="radio-dot"></span> Pre-Order</span>
                        </label>
                    </div>
                    <input type="hidden" name="variantAvailabilities" value="In Stock" class="variant-availability-hidden">
                </div>

                <div class="field" style="margin-top:10px;">
                    <label class="field-label">Barcode Preview</label>
                    <svg class="variant-barcode" style="width:180px;height:auto;"></svg>
                </div>
            `;

            const uploadBtn = card.querySelector('.variant-img-upload');
            const fileInput = card.querySelector('.hidden-color-input');
            const skuInput = card.querySelector('input[name="variantSkus"]');
            const barcodeSvg = card.querySelector('.variant-barcode');
            const availabilityHidden = card.querySelector('.variant-availability-hidden');
            uploadBtn.addEventListener('click', () => openImageSelector(uploadBtn, fileInput));
            
            card.querySelectorAll(`input[name="${groupName}"]`).forEach(radio => {
                radio.addEventListener('change', () => {
                    if (radio.checked && availabilityHidden) {
                        availabilityHidden.value = radio.value;
                    }
                });
            });

            if (skuInput) {
                // If variant has an SKU in the CSV mapping, don't overwrite it immediately. We'll set it below.
                skuInput.value = generateSKU();
                updateVariantBarcode(barcodeSvg, skuInput.value);
                skuInput.addEventListener('input', () => updateVariantBarcode(barcodeSvg, skuInput.value));
            }

            card.querySelector('.variant-remove-btn').addEventListener('click', () => {
                if (variantsContainer.querySelectorAll('.variant-card').length > 1) {
                    card.remove();
                    renumberVariantFileInputs();
                    renumberVariantLabels();
                    computeStockAndSizes();
                }
            });

            variantsContainer.appendChild(card);

            if (variant) {
                const nameInput = card.querySelector('input[name="colorNames"]');
                const stockInput = card.querySelector('input[name="colorStocks"]');
                const sizeInput = card.querySelector('input[name="colorSizes"]');
                const priceInput = card.querySelector('input[name="variantPrices"]');
                const skuVariantInput = card.querySelector('input[name="variantSkus"]');
                const weightInput = card.querySelector('input[name="variantWeights"]');
                const lengthInput = card.querySelector('input[name="variantLengths"]');
                const heightInput = card.querySelector('input[name="variantHeights"]');
                const widthInput = card.querySelector('input[name="variantWidths"]');
                const inStockRadio = card.querySelector(`input[name="${groupName}"][value="In Stock"]`);
                const preOrderRadio = card.querySelector(`input[name="${groupName}"][value="Pre-Order"]`);
                
                if (nameInput) nameInput.value = variant.Style ?? variant.ColorName ?? '';
                if (stockInput) stockInput.value = variant.Quantity ?? variant.Stock ?? '';
                if (sizeInput) sizeInput.value = variant.Size ?? variant.Sizes ?? '';
                if (priceInput) priceInput.value = variant.Price != null && variant.Price !== '' ? variant.Price.toString() : '';
                if (skuVariantInput && variant.SKU) skuVariantInput.value = variant.SKU;
                if (weightInput) weightInput.value = variant.Weight ?? '';
                if (lengthInput) lengthInput.value = variant.Length ?? '';
                if (heightInput) heightInput.value = variant.Height ?? '';
                if (widthInput) widthInput.value = variant.Width ?? '';
                if (availabilityHidden) {
                    availabilityHidden.value = variant.Availability ?? 'In Stock';
                }
                if ((variant.Availability ?? 'In Stock') === 'Pre-Order') {
                    if (preOrderRadio) preOrderRadio.checked = true;
                } else {
                    if (inStockRadio) inStockRadio.checked = true;
                }
                updateVariantBarcode(barcodeSvg, skuVariantInput ? skuVariantInput.value : '');
                computeStockAndSizes();
            }

            variantCount++;
            renumberVariantFileInputs();
        }

        function renumberVariantLabels() {
            variantsContainer.querySelectorAll('.variant-card').forEach((card, i) => {
                const lbl = card.querySelector('.variant-number');
                if (lbl) lbl.textContent = `Variant ${i + 1}`;
            });
        }

        btnAddVariant.addEventListener('click', () => addVariantRow());

        function computeStockAndSizes() {
            const totalStock = Array.from(variantsContainer.querySelectorAll('input[name="colorStocks"]'))
                .reduce((sum, el) => sum + (parseInt(el.value || '0', 10) || 0), 0);
            document.getElementById('stockHidden').value = totalStock;

            const sizes = [];
            variantsContainer.querySelectorAll('input[name="colorSizes"]').forEach(el => {
                const sizeVal = (el.value || '').trim();
                if (sizeVal && !sizes.includes(sizeVal)) sizes.push(sizeVal);
            });
            document.getElementById('sizesHidden').value = sizes.join(',');

            const firstVariantSku = variantsContainer.querySelector('input[name="variantSkus"]');
            if (firstVariantSku) {
                skuHidden.value = firstVariantSku.value || '';
            }
        }

        variantsContainer.addEventListener('input', e => {
            if (e.target.matches('input[name="colorStocks"], input[name="colorSizes"]')) computeStockAndSizes();
        });

        form.addEventListener('submit', computeStockAndSizes);
    </script>
</body>
</html>