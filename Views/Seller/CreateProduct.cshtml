@model MyAspNetApp.Models.DbProduct
@{
    ViewData["Title"] = "Manage Product Listing";
    Layout = null;
    var mode = ViewBag.Mode as string ?? "create";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON - Manage Product Listing</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>

    <link rel="stylesheet" href="~/css/createProduct.css" />
</head>
<body>

    <header class="top-nav">
        <div class="logo">
            <div style="background: black; color: white; padding: 2px 10px; border-radius: 6px;">H</div>
            NEXT HORIZON
        </div>
        <div class="nav-actions">
            <i class="fa-regular fa-bell" style="font-size: 1.4rem; cursor: pointer;"></i>
            <div style="display: flex; align-items: center; gap: 10px; cursor: pointer;">
                <i class="fa-regular fa-circle-user" style="font-size: 1.8rem;"></i>
                <span style="font-weight: 600;">Seller</span>
                <i class="fa-solid fa-chevron-down" style="font-size: 0.7rem;"></i>
            </div>
        </div>
    </header>

    <div class="container">
        <h2 class="page-title" id="dynamic-page-title">Create Product Listing</h2>

        <form asp-action="CreateProduct" asp-controller="Seller" method="post" enctype="multipart/form-data" id="productForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="mode" value="@mode" />
            <input type="hidden" asp-for="ProductId" />
            <input type="hidden" asp-for="Status" value="@(mode == "relist" ? "active" : (Model.Status ?? "active"))" />
            <input type="hidden" asp-for="Sizes" id="sizesHidden" />
            <input type="hidden" asp-for="Stock" id="stockHidden" />
            <input type="hidden" id="hiddenProductSku" name="SKU" value="" />

            <input type="file" id="imageInput" name="imageFile" multiple accept="image/*" style="display: none;">

            <div class="main-upload-box" id="uploadBox">
                <i class="fa-solid fa-cloud-arrow-up"></i>
                <span>Upload Photos</span>
            </div>

            <div class="thumbnail-row" id="thumbnailRow"></div>

            <h3 class="section-title">Product Details</h3>

            <div class="form-row">
                <input type="text" class="custom-input" placeholder="Product Name" asp-for="ProductName" value="@Model.ProductName">
            </div>

            <div class="form-row">
                <input type="text" class="custom-input" placeholder="Brand" asp-for="Brand" value="@Model.Brand">
            </div>

            <div class="form-row" style="margin-bottom: 5px;">
                <div class="split-input-box">
                    <input type="number" id="basePrice" placeholder="Price" min="0" step="any" asp-for="Price" value="@(Model.Price > 0 ? Model.Price.ToString("0.##") : "")">
                    <div class="discount-wrap">
                        <span style="color: #444;">Discount |</span>
                        <input type="number" id="discountPercent" placeholder="0" min="0" max="100" asp-for="Discount" value="@(Model.Discount.HasValue && Model.Discount.Value > 0 ? Model.Discount.Value.ToString("0.##") : "")">
                    </div>
                </div>
                <div style="text-align: right; font-size: 0.95rem; color: #555; padding-right: 10px; margin-top: 8px;">
                    Final Price: <span id="finalPriceDisplay" style="font-weight: 700; color: #111;">0.00</span>
                </div>
            </div>

            <div class="form-row">
                <input list="category-options" class="custom-input" asp-for="Category" value="@Model.Category" placeholder="Category">
                <datalist id="category-options">
                    <option value="Tops"></option>
                    <option value="Bottoms"></option>
                    <option value="Outerwear"></option>
                    <option value="Footwear"></option>
                    <option value="Accessories"></option>
                </datalist>
            </div>

            <div class="form-row">
                <select class="custom-input" asp-for="Gender" required>
                    <option value="" disabled>Select gender</option>
                    <option value="Men">Men</option>
                    <option value="Women">Women</option>
                    <option value="Unisex">Unisex</option>
                </select>
            </div>

            <div id="variants-container"></div>

            <div class="add-variant-row">
                <button type="button" class="btn-add-variant" id="btnAddVariant">Add Size & Style</button>
                <a href="/Product/sizeguide" class="size-guide-link">
                    Size Guide
                    <i class="fa-solid fa-ruler-horizontal"></i>
                </a>
            </div>

            <div class="bottom-details-row">
                <textarea class="custom-input" placeholder="Product Details" asp-for="Details">@Model.Details</textarea>
                <div class="barcode-preview-box">
                    <span>Barcode Preview</span>
                    <svg id="liveBarcodePreview"></svg>
                </div>
            </div>

            <div class="action-buttons">
                <button type="button" class="btn-cancel" onclick="window.history.back()">Cancel</button>
                <button type="submit" class="btn-submit" id="dynamic-submit-btn">Add Product</button>
            </div>
        </form>
    </div>

    <div class="overlay-modal" id="imageModal">
        <div class="overlay-content">
            <h3>Select Variant Images</h3>
            <div class="grid-selector" id="modalGrid"></div>

            <div style="display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px;">
                <button type="button" class="btn-modal" style="background:#fff; color:#111; border:1px solid #111;" onclick="document.getElementById('imageModal').style.display='none'">Cancel</button>
                <button type="button" class="btn-modal" onclick="applySelectedPhotos()">Apply</button>
            </div>
        </div>
    </div>

    <script>
        const mode = '@mode';
        const form = document.getElementById('productForm');
        const pageTitle = document.getElementById('dynamic-page-title');
        const submitBtn = document.getElementById('dynamic-submit-btn');
        const variantsContainer = document.getElementById('variants-container');
        const btnAddVariant = document.getElementById('btnAddVariant');
        const uploadBox = document.getElementById('uploadBox');
        const imageInput = document.getElementById('imageInput');
        const thumbnailRow = document.getElementById('thumbnailRow');
        const skuHidden = document.getElementById('hiddenProductSku');
        const priceInput = document.getElementById('basePrice');
        const discountInput = document.getElementById('discountPercent');
        const finalPriceDisplay = document.getElementById('finalPriceDisplay');
        const imageModal = document.getElementById('imageModal');
        const modalGrid = document.getElementById('modalGrid');
        let variantCount = 0;
        let selectedMainFiles = [];
        let currentSku = '';
        let currentVariantBtn = null;
        let currentVariantFileInput = null;
        let selectedPhotosForVariant = [];

        document.addEventListener('DOMContentLoaded', () => {
            if (mode === 'edit') {
                pageTitle.innerText = 'Edit Product Listing';
                submitBtn.innerText = 'Update Product';
            } else if (mode === 'relist') {
                pageTitle.innerText = 'Relist Product Listing';
                submitBtn.innerText = 'Relist Product';
            } else if (mode === 'renew') {
                pageTitle.innerText = 'Renew Product Listing';
                submitBtn.innerText = 'Renew Product';
            }

            resetSku();
            addVariantRow();
            calculateFinalPrice();
        });

        function resetSku() {
            currentSku = generateSKU();
            skuHidden.value = currentSku;
            updateBarcodePreview(currentSku);
            setSkuOnRows();
        }

        function setSkuOnRows() {
            variantsContainer.querySelectorAll('.sku-display').forEach(input => {
                input.value = currentSku;
            });
        }

        function updateBarcodePreview(value) {
            if (!value || value.trim() === '') return;
            try {
                JsBarcode('#liveBarcodePreview', value.trim(), {
                    format: 'CODE128',
                    lineColor: '#000000',
                    background: 'transparent',
                    width: 2,
                    height: 60,
                    displayValue: true,
                    fontSize: 16,
                    font: 'Inter',
                    margin: 0
                });
            } catch { }
        }

        function generateSKU() {
            const part = Math.random().toString(36).slice(2, 10).toUpperCase();
            return `SKU-${part}`;
        }

        function calculateFinalPrice() {
            const price = parseFloat(priceInput.value) || 0;
            let discount = parseFloat(discountInput.value) || 0;
            if (discount > 100) {
                discount = 100;
                discountInput.value = '100';
            }
            finalPriceDisplay.innerText = (price - (price * (discount / 100))).toFixed(2);
        }

        priceInput.addEventListener('input', calculateFinalPrice);
        discountInput.addEventListener('input', calculateFinalPrice);

        uploadBox.addEventListener('click', () => imageInput.click());

        function syncMainFileInput() {
            const dt = new DataTransfer();
            selectedMainFiles.forEach(file => dt.items.add(file));
            imageInput.files = dt.files;
        }

        function renderMainThumbnails() {
            thumbnailRow.innerHTML = '';
            selectedMainFiles.forEach((file, index) => {
                const url = URL.createObjectURL(file);
                const thumb = document.createElement('div');
                thumb.className = 'thumbnail';
                thumb.innerHTML = `<img src="${url}" alt="Uploaded Photo">`;
                thumb.onclick = () => {
                    selectedMainFiles.splice(index, 1);
                    syncMainFileInput();
                    renderMainThumbnails();
                };
                thumbnailRow.appendChild(thumb);
            });
        }

        imageInput.addEventListener('change', () => {
            for (const file of imageInput.files) {
                selectedMainFiles.push(file);
            }
            syncMainFileInput();
            renderMainThumbnails();
        });

        function isSameFile(a, b) {
            return a && b &&
                a.name === b.name &&
                a.size === b.size &&
                a.lastModified === b.lastModified;
        }

        function openImageSelector(btn, fileInput) {
            currentVariantBtn = btn;
            currentVariantFileInput = fileInput;
            selectedPhotosForVariant = Array.from(fileInput.files || []);
            modalGrid.innerHTML = '';

            if (selectedMainFiles.length === 0) {
                modalGrid.innerHTML = '<p style="grid-column: 1 / -1; color: #555;">Please upload some photos first using the big cloud box above.</p>';
            } else {
                selectedMainFiles.forEach(file => {
                    const url = URL.createObjectURL(file);
                    const imgContainer = document.createElement('div');
                    imgContainer.className = 'modal-img-container';

                    const img = document.createElement('img');
                    img.src = url;
                    const isSelected = selectedPhotosForVariant.some(f => isSameFile(f, file));
                    img.style.borderColor = isSelected ? '#111' : 'transparent';
                    imgContainer.appendChild(img);

                    imgContainer.onclick = () => {
                        const idx = selectedPhotosForVariant.findIndex(f => isSameFile(f, file));
                        if (idx > -1) {
                            selectedPhotosForVariant.splice(idx, 1);
                            img.style.borderColor = 'transparent';
                        } else {
                            selectedPhotosForVariant.push(file);
                            img.style.borderColor = '#111';
                        }
                    };
                    modalGrid.appendChild(imgContainer);
                });
            }
            imageModal.style.display = 'flex';
        }

        window.applySelectedPhotos = function () {
            if (!currentVariantBtn || !currentVariantFileInput) {
                imageModal.style.display = 'none';
                return;
            }

            const dt = new DataTransfer();
            selectedPhotosForVariant.forEach(file => dt.items.add(file));
            currentVariantFileInput.files = dt.files;

            currentVariantBtn.innerHTML = '';

            if (selectedPhotosForVariant.length > 0) {
                selectedPhotosForVariant.slice(0, 4).forEach(file => {
                    const img = document.createElement('img');
                    img.src = URL.createObjectURL(file);
                    currentVariantBtn.appendChild(img);
                });

                const removeBtn = document.createElement('button');
                removeBtn.type = 'button';
                removeBtn.className = 'delete-btn';
                removeBtn.innerHTML = '<i class="fa-solid fa-xmark"></i>';
                removeBtn.onclick = e => {
                    e.stopPropagation();
                    currentVariantFileInput.value = '';
                    currentVariantBtn.innerHTML = '<i class="fa-solid fa-plus" style="font-weight:300;"></i>';
                };
                currentVariantBtn.appendChild(removeBtn);
            } else {
                currentVariantBtn.innerHTML = '<i class="fa-solid fa-plus" style="font-weight:300;"></i>';
            }

            imageModal.style.display = 'none';
        };

        function renumberVariantFileInputs() {
            const cards = variantsContainer.querySelectorAll('.variant-card');
            cards.forEach((card, i) => {
                const fileInput = card.querySelector('.hidden-color-input');
                const existingPaths = card.querySelector('.existing-color-paths');
                if (fileInput) fileInput.name = `colorFiles_${i}`;
                if (existingPaths) existingPaths.name = `existingColorPaths_${i}`;
            });
        }

        function addVariantRow() {
            const availabilityGroupName = `availability-${variantCount}`;
            const card = document.createElement('div');
            card.className = 'variant-card';
            card.innerHTML = `
                <div class="variant-row">
                    <button type="button" class="btn-plus-square" title="Upload color photos">
                        <i class="fa-solid fa-plus" style="font-weight:300;"></i>
                    </button>
                    <input type="file" class="hidden-color-input" multiple accept="image/*" style="display:none;">
                    <input type="hidden" class="existing-color-paths" value="">

                    <div class="input-with-label">
                        <span class="label">SKU</span><div class="vertical-line"></div>
                        <input type="text" class="sku-display" readonly>
                    </div>
                    <div class="input-with-label">
                        <span class="label">Size</span><div class="vertical-line"></div>
                        <input type="text" name="colorSizes" placeholder="Size">
                    </div>
                    <div class="input-with-label">
                        <span class="label">Style</span><div class="vertical-line"></div>
                        <input type="text" name="colorNames" placeholder="Style">
                    </div>
                    <div class="input-with-label">
                        <span class="label">Quantity</span><div class="vertical-line"></div>
                        <input type="number" name="colorStocks" class="qty-input" placeholder="0" min="0">
                    </div>
                </div>

                <div class="variant-row">
                    <div style="display: flex; align-items: center; gap: 15px; margin-right: 10px;">
                        <span style="font-weight: 700; font-size: 1.05rem;">Availability</span>
                        <div style="display: flex; flex-direction: column; gap: 8px;">
                            <label class="custom-radio">
                                <input type="radio" name="${availabilityGroupName}" checked>
                                <div class="radio-box"></div> In Stock
                            </label>
                            <label class="custom-radio">
                                <input type="radio" name="${availabilityGroupName}">
                                <div class="radio-box"></div> Pre Order
                            </label>
                        </div>
                    </div>

                    <div class="input-with-label">
                        <span class="label">Weight</span><div class="vertical-line"></div>
                        <input type="number" placeholder="0">
                        <div class="unit-selector">
                            <i class="fa-solid fa-caret-down"></i>
                            <select><option>Kg</option><option>lb</option><option>g</option></select>
                        </div>
                    </div>
                    <div class="input-with-label">
                        <span class="label">Length</span><div class="vertical-line"></div>
                        <input type="number" placeholder="0">
                        <div class="unit-selector">
                            <i class="fa-solid fa-caret-down"></i>
                            <select><option>in</option><option>cm</option></select>
                        </div>
                    </div>
                    <div class="input-with-label">
                        <span class="label">Height</span><div class="vertical-line"></div>
                        <input type="number" placeholder="0">
                        <div class="unit-selector">
                            <i class="fa-solid fa-caret-down"></i>
                            <select><option>in</option><option>cm</option></select>
                        </div>
                    </div>
                    <div class="input-with-label">
                        <span class="label">Width</span><div class="vertical-line"></div>
                        <input type="number" placeholder="0">
                        <div class="unit-selector">
                            <i class="fa-solid fa-caret-down"></i>
                            <select><option>in</option><option>cm</option></select>
                        </div>
                    </div>
                </div>
            `;

            const uploadBtn = card.querySelector('.btn-plus-square');
            const fileInput = card.querySelector('.hidden-color-input');

            uploadBtn.addEventListener('click', () => openImageSelector(uploadBtn, fileInput));

            variantsContainer.appendChild(card);
            variantCount++;
            setSkuOnRows();
            renumberVariantFileInputs();
        }

        btnAddVariant.addEventListener('click', addVariantRow);

        function computeStockAndSizes() {
            const qtyInputs = Array.from(variantsContainer.querySelectorAll('input[name="colorStocks"]'));
            const sizeInputs = Array.from(variantsContainer.querySelectorAll('input[name="colorSizes"]'));

            const totalStock = qtyInputs.reduce((sum, input) => sum + (parseInt(input.value || '0', 10) || 0), 0);
            document.getElementById('stockHidden').value = totalStock;

            const sizes = [];
            sizeInputs.forEach(input => {
                const split = (input.value || '').split(',').map(s => s.trim()).filter(Boolean);
                split.forEach(v => { if (!sizes.includes(v)) sizes.push(v); });
            });
            document.getElementById('sizesHidden').value = sizes.join(',');
        }

        variantsContainer.addEventListener('input', e => {
            if (e.target.matches('input[name="colorStocks"], input[name="colorSizes"]')) {
                computeStockAndSizes();
            }
        });

        form.addEventListener('submit', () => {
            computeStockAndSizes();
        });
    </script>
</body>
</html>
