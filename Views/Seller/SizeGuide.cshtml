@{
    ViewData["Title"] = "Product Size Guide";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEXT HORIZON — Product Size Guide</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,300&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link rel="stylesheet" href="~/css/SizeGuide.css" />
</head>
<body>

    <aside class="sidebar">
        <div class="logo">
            <div style="background: white; color: black; padding: 2px 10px; border-radius: 6px;">H</div>
            NEXT HORIZON
        </div>
        <nav>
            <a href="#" class="nav-item"><i class="fa-solid fa-house"></i> Dashboard</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-receipt"></i> Orders</a>
            <a href="#" class="nav-item active"><i class="fa-solid fa-bag-shopping"></i> Products</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-wallet"></i> Finances</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-chart-line"></i> Analytics</a>
            <a href="#" class="nav-item"><i class="fa-solid fa-gear"></i> Settings</a>
        </nav>
    </aside>

    <div class="main-wrapper">

        <header class="top-nav">
            <div class="nav-left">
                <a href="#" class="logo">
                    <div class="logo-mark">H</div>
                    Next Horizon
                </a>
                <div class="nav-divider"></div>
                <div class="nav-breadcrumb">
                    <span>Seller Portal</span>
                    <i class="fa-solid fa-chevron-right" style="font-size:9px; color:var(--border-strong);"></i>
                    <span>Products</span>
                    <i class="fa-solid fa-chevron-right" style="font-size:9px; color:var(--border-strong);"></i>
                    <strong>Size Guide</strong>
                </div>
            </div>
            <div class="nav-right">
                <button class="nav-icon-btn"><i class="fa-regular fa-bell"></i></button>
                <div class="nav-user">
                    <div class="nav-avatar">SE</div>
                    <span>Seller</span>
                    <i class="fa-solid fa-chevron-down"></i>
                </div>
            </div>
        </header>

        <div class="page-wrapper">

            <div class="page-header">
                <div class="page-header-left">
                    <div class="page-eyebrow">Listing Configurations</div>
                    <h1 class="page-title">Product Size Guide</h1>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon"><i class="fa-solid fa-tag"></i></div>
                    <div>
                        <div class="card-title">Size Guide Identity</div>
                        <div class="card-subtitle">Name your size guide to easily attach it to products later.</div>
                    </div>
                </div>
                <div class="field">
                    <label class="field-label">Size Guide Title</label>
                    <input type="text" class="field-input" id="sizeGuideTitle" placeholder="e.g. Men's Standard Tops">
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon"><i class="fa-regular fa-image"></i></div>
                    <div>
                        <div class="card-title">Upload Existing Guide</div>
                        <div class="card-subtitle">Upload a pre-made size guide graphic if you have one.</div>
                    </div>
                </div>

                <input type="file" id="imageInput" multiple accept="image/*" style="display: none;">
                <div class="upload-zone" id="uploadBox">
                    <div class="upload-zone-icon"><i class="fa-solid fa-arrow-up-from-bracket"></i></div>
                    <div class="upload-zone-text">
                        <strong>Click to upload photos</strong>
                        <span>PNG, JPG, WEBP — up to 10MB each</span>
                    </div>
                </div>
                <div class="thumbnail-strip" id="thumbnailRow"></div>
            </div>

            <div class="divider-container">
                <span>OR BUILD A CUSTOM ONE</span>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon"><i class="fa-solid fa-table"></i></div>
                    <div>
                        <div class="card-title">Create Dynamic Size Table</div>
                        <div class="card-subtitle">Generate a custom measurement table for this guide.</div>
                    </div>
                </div>

                <div class="field-group cols-2" style="margin-bottom: 16px;">
                    <div class="field">
                        <label class="field-label">Measurement Unit</label>
                        <select class="field-input" id="measurementUnit">
                            <option value="" disabled selected>Select unit</option>
                            <option value="cm">Centimeters (cm)</option>
                            <option value="in">Inches (in)</option>
                        </select>
                    </div>
                    <div class="field">
                        <label class="field-label">Category</label>
                        <select class="field-input" id="categorySelect">
                            <option value="" disabled selected>Select category</option>
                            <option value="Tops">Tops</option>
                            <option value="Bottoms">Bottoms</option>
                            <option value="Footwear">Footwear</option>
                            <option value="Outerwear">Outerwear</option>
                            <option value="Dresses & Jumpsuits">Dresses &amp; Jumpsuits</option>
                            <option value="Activewear">Activewear</option>
                            <option value="Accessories">Accessories</option>
                        </select>
                    </div>
                </div>

                <button class="btn-outline-dashed" id="btnShowCreateTableModal" style="margin-bottom: 24px;">
                    <i class="fa-solid fa-plus"></i> Add Table
                </button>

                <div id="dynamic-tables-container"></div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-icon"><i class="fa-solid fa-circle-info"></i></div>
                    <div>
                        <div class="card-title">Additional Information</div>
                        <div class="card-subtitle">Provide context to help buyers measure correctly.</div>
                    </div>
                </div>

                <div class="field-group" style="margin-bottom: 10px;">
                    <div class="field">
                        <label class="field-label">Fit Tips</label>
                        <textarea class="field-input" id="fitTips" placeholder="e.g., Fits true to size, take your normal size."></textarea>
                    </div>
                </div>
                <div class="field-group cols-2">
                    <div class="field">
                        <label class="field-label">How to Measure</label>
                        <textarea class="field-input" id="howToMeasure" placeholder="e.g., Chest: Measure around the fullest part of your chest..."></textarea>
                    </div>
                    <div class="field">
                        <label class="field-label">Additional Notes</label>
                        <textarea class="field-input" id="additionalNotes" placeholder="Additional Details (Optional)"></textarea>
                    </div>
                </div>
            </div>

            <div class="form-footer">
                <div class="form-footer-left">
                    Ensure measurements are accurate to reduce returns.
                </div>
                <div class="form-footer-right">
                    <a href="/Seller/CreateProduct" class="btn btn-ghost">Cancel</a>
                    <button class="btn btn-primary" id="btnSaveSizeGuide">
                        <i class="fa-solid fa-check"></i> Save Size Guide
                    </button>
                </div>
            </div>

        </div> </div> <div class="overlay-modal" id="createTableModal">
        <div class="overlay-content" style="width: 400px;">
            <div class="modal-header">
                <span class="modal-title">Table Dimensions</span>
                <button type="button" class="modal-close" onclick="closeModal('createTableModal')">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body">
                <p style="color: var(--text-secondary); margin-bottom: 16px; font-size: 13px;">How many columns and rows do you need?</p>
                <div class="field-group cols-2">
                    <div class="field">
                        <label class="field-label">Columns</label>
                        <input type="number" class="field-input" id="colCountInput" min="1" value="5">
                    </div>
                    <div class="field">
                        <label class="field-label">Rows</label>
                        <input type="number" class="field-input" id="rowCountInput" min="1" value="4">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="closeModal('createTableModal')">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnGenerateTable">Generate</button>
            </div>
        </div>
    </div>

    <div class="overlay-modal" id="deleteRowColModal">
        <div class="overlay-content" style="width: 400px;">
            <div class="modal-header">
                <span class="modal-title">Delete Options</span>
                <button type="button" class="modal-close" onclick="closeModal('deleteRowColModal')">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            <div class="modal-body" style="text-align: center;">
                <p style="color: var(--text-secondary); font-size: 13px; margin-bottom: 20px;">What would you like to remove from this table?</p>
                
                <div style="display: flex; flex-direction: column; gap: 10px;">
                    <button class="btn btn-secondary" id="btnConfirmDeleteRow" style="justify-content: center;">Delete Last Row</button>
                    <button class="btn btn-secondary" id="btnConfirmDeleteCol" style="justify-content: center;">Delete Last Column</button>
                    <button class="btn btn-primary" id="btnConfirmDeleteTable" style="justify-content: center; background: var(--red);">Delete Entire Table</button>
                </div>

                <p id="deleteWarning" style="color: var(--red); font-size: 12px; margin-top: 15px; display: none; font-weight: 500;">
                    <i class="fa-solid fa-triangle-exclamation"></i> Cannot delete the last remaining row/column!
                </p>
            </div>
        </div>
    </div>


    <script>
        // --- 1. Image Upload Logic ---
        const uploadBox = document.getElementById('uploadBox');
        const imageInput = document.getElementById('imageInput');
        const thumbnailRow = document.getElementById('thumbnailRow');

        uploadBox.addEventListener('click', () => imageInput.click());

        imageInput.addEventListener('change', function(event) {
            const files = event.target.files;
            for (let i = 0; i < files.length; i++) {
                const imageUrl = URL.createObjectURL(files[i]);
                const thumbDiv = document.createElement('div');
                thumbDiv.className = 'thumb-item'; // Updated to match CSS
                thumbDiv.innerHTML = `
                    <img src="${imageUrl}" alt="Uploaded Photo">
                    <button type="button" class="thumb-delete" onclick="this.parentElement.remove()">
                        <i class="fa-solid fa-xmark"></i>
                    </button>
                `;
                thumbnailRow.appendChild(thumbDiv);
            }
            imageInput.value = '';
        });

        // --- 2. Modal Utility Functions ---
        function openModal(id) { 
            document.getElementById(id).style.display = 'flex'; 
        }
        function closeModal(id) {
            document.getElementById(id).style.display = 'none';
            if (id === 'deleteRowColModal') {
                document.getElementById('deleteWarning').style.display = 'none';
            }
        }

        // --- 3. Dynamic Table Generation Logic ---
        const btnShowCreateTableModal = document.getElementById('btnShowCreateTableModal');
        const btnGenerateTable = document.getElementById('btnGenerateTable');
        const tablesContainer = document.getElementById('dynamic-tables-container');

        let targetTableForDeletion = null;

        btnShowCreateTableModal.addEventListener('click', () => {
            openModal('createTableModal');
        });

        btnGenerateTable.addEventListener('click', () => {
            const cols = parseInt(document.getElementById('colCountInput').value) || 5;
            const rows = parseInt(document.getElementById('rowCountInput').value) || 4;

            createDynamicTable(rows, cols);
            closeModal('createTableModal');
        });

        function createDynamicTable(rows, cols) {
            const wrapper = document.createElement('div');
            wrapper.className = 'table-wrapper';

            const titleInputHTML = `<input type="text" class="field-input" placeholder="Table Title (e.g. Tops)" style="margin-bottom: 12px; font-weight: 600;">`;
            const addColBtn = `<button type="button" class="corner-btn btn-add-col" title="Add Column"><i class="fa-solid fa-plus"></i></button>`;
            const addRowBtn = `<button type="button" class="corner-btn btn-add-row" title="Add Row"><i class="fa-solid fa-plus"></i></button>`;
            const delRcBtn = `<button type="button" class="corner-btn btn-delete-rc" title="Delete Options"><i class="fa-solid fa-xmark"></i></button>`;

            let tableHTML = `<div class="table-inner-wrapper"><table class="size-guide-table"><tbody>`;
            
            for (let r = 0; r < rows; r++) {
                tableHTML += `<tr>`;
                for (let c = 0; c < cols; c++) {
                    tableHTML += `<td><input type="text" placeholder="${r===0 ? 'Header' : '-'}"></td>`;
                }
                tableHTML += `</tr>`;
            }
            tableHTML += `</tbody></table></div>`;
            
            wrapper.innerHTML = titleInputHTML + `<div style="position: relative;">` + addColBtn + addRowBtn + delRcBtn + tableHTML + `</div>`;
            tablesContainer.appendChild(wrapper);
        }

        // --- 4. Table Interaction Logic ---
        tablesContainer.addEventListener('click', function(e) {
            const target = e.target.closest('.corner-btn');
            if (!target) return;

            const wrapper = target.closest('.table-wrapper');
            const tableBody = wrapper.querySelector('tbody');
            const rows = tableBody.querySelectorAll('tr');

            // Add Column
            if (target.classList.contains('btn-add-col')) {
                rows.forEach((row, index) => {
                    const newCell = document.createElement('td');
                    newCell.innerHTML = `<input type="text" placeholder="${index===0 ? 'Header' : '-'}">`;
                    row.appendChild(newCell);
                });
            }

            // Add Row
            if (target.classList.contains('btn-add-row')) {
                const colCount = rows[0].querySelectorAll('td').length;
                const newRow = document.createElement('tr');
                for (let i = 0; i < colCount; i++) {
                    const newCell = document.createElement('td');
                    newCell.innerHTML = `<input type="text" placeholder="-">`;
                    newRow.appendChild(newCell);
                }
                tableBody.appendChild(newRow);
            }

            // Delete Options -> Opens Modal
            if (target.classList.contains('btn-delete-rc')) {
                targetTableForDeletion = tableBody;
                openModal('deleteRowColModal');
            }
        });

        // --- 5. Delete Modal Action Logic ---
        document.getElementById('btnConfirmDeleteRow').addEventListener('click', () => {
            if (!targetTableForDeletion) return;
            const rows = targetTableForDeletion.querySelectorAll('tr');

            if (rows.length <= 1) {
                document.getElementById('deleteWarning').style.display = 'block';
                return;
            }

            targetTableForDeletion.removeChild(rows[rows.length - 1]);
            closeModal('deleteRowColModal');
        });

        document.getElementById('btnConfirmDeleteCol').addEventListener('click', () => {
            if (!targetTableForDeletion) return;
            const rows = targetTableForDeletion.querySelectorAll('tr');

            const colCount = rows[0].querySelectorAll('td').length;
            if (colCount <= 1) {
                document.getElementById('deleteWarning').style.display = 'block';
                return;
            }

            rows.forEach(row => {
                const cells = row.querySelectorAll('td');
                row.removeChild(cells[cells.length - 1]);
            });
            closeModal('deleteRowColModal');
        });

        document.getElementById('btnConfirmDeleteTable').addEventListener('click', () => {
            if (!targetTableForDeletion) return;

            const entireTableWrapper = targetTableForDeletion.closest('.table-wrapper');
            if (entireTableWrapper) {
                entireTableWrapper.remove();
            }
            closeModal('deleteRowColModal');
        });

        // --- 6. Save Size Guide ---
        document.getElementById('btnSaveSizeGuide').addEventListener('click', () => {
            alert('Size guide saved! (Connect to server when ready.)');
        });
    </script>
</body>
</html>