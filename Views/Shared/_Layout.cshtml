<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="NEXT HORIZON - Premium Running Gear. Engineered for Performance. Built for Runners.">
    <meta name="theme-color" content="#000000">
    <title>@ViewData["Title"] - NEXT HORIZON</title>
    
    <!-- Preconnect for Performance -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <!-- Premium Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100;200;300;400;500;600;700;800;900&family=Space+Grotesk:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Styles -->
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true">
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    @{
        var _isShop = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower() == "shop";
    }
    @if (_isShop)
    {
    <!-- ── Promo Announcement Bar (shop only, no close) ── -->
    <div id="promo-bar" class="promo-bar">
        <div class="promo-bar-track">
            <span id="promo-bar-msg" class="promo-bar-msg"></span>
        </div>
    </div>
    }

    <!-- ── Main Header ────────────────────────────────── -->
    <header id="main-header">
        <div class="header-inner">
            <div class="header-content">

                <!-- Logo -->
                <div class="logo">
                    <a href="/"><img src="/logo.png" alt="NEXT HORIZON" class="header-logo-img"></a>
                </div>

                <!-- Mega Nav — only on Shop page -->
                @{
                    var isShopPage = ViewContext.RouteData.Values["action"]?.ToString()?.ToLower() == "shop";
                }
                @if (isShopPage)
                {
                <nav class="mega-nav" id="main-nav" aria-label="Shop navigation">

                    <!-- Men -->
                    <div class="mega-item">
                        <a href="/Home/Shop?gender=men" class="mega-link">Men</a>
                        <div class="mega-panel">
                            <div class="mega-col">
                                <h4 class="mega-col-title">Shoes</h4>
                                <a href="/Home/Shop?gender=men&cat=running-shoes">Running Shoes</a>
                                <a href="/Home/Shop?gender=men&cat=trail-shoes">Trail Shoes</a>
                                <a href="/Home/Shop?gender=men&cat=racing-shoes">Racing Shoes</a>
                                <a href="/Home/Shop?gender=men&cat=casual">Lifestyle</a>
                            </div>
                            <div class="mega-col">
                                <h4 class="mega-col-title">Clothing</h4>
                                <a href="/Home/Shop?gender=men&cat=tops">Tops &amp; T-Shirts</a>
                                <a href="/Home/Shop?gender=men&cat=shorts">Shorts</a>
                                <a href="/Home/Shop?gender=men&cat=jackets">Jackets</a>
                                <a href="/Home/Shop?gender=men&cat=tights">Tights</a>
                            </div>
                            <div class="mega-col">
                                <h4 class="mega-col-title">Accessories</h4>
                                <a href="/Home/Shop?gender=men&cat=socks">Socks</a>
                                <a href="/Home/Shop?gender=men&cat=caps">Caps &amp; Hats</a>
                                <a href="/Home/Shop?gender=men&cat=bags">Bags</a>
                                <a href="/Home/Shop?gender=men&cat=insoles">Insoles</a>
                            </div>
                            <div class="mega-col">
                                <h4 class="mega-col-title">Sports</h4>
                                <a href="/Home/Shop?gender=men&sport=road-running">Road Running</a>
                                <a href="/Home/Shop?gender=men&sport=trail-running">Trail Running</a>
                                <a href="/Home/Shop?gender=men&sport=gym">Gym &amp; Training</a>
                                <a href="/Home/Shop?gender=men&sport=race-day">Race Day</a>
                            </div>
                        </div>
                    </div>

                    <!-- Women -->
                    <div class="mega-item">
                        <a href="/Home/Shop?gender=women" class="mega-link">Women</a>
                        <div class="mega-panel">
                            <div class="mega-col">
                                <h4 class="mega-col-title">Shoes</h4>
                                <a href="/Home/Shop?gender=women&cat=running-shoes">Running Shoes</a>
                                <a href="/Home/Shop?gender=women&cat=trail-shoes">Trail Shoes</a>
                                <a href="/Home/Shop?gender=women&cat=racing-shoes">Racing Shoes</a>
                                <a href="/Home/Shop?gender=women&cat=casual">Lifestyle</a>
                            </div>
                            <div class="mega-col">
                                <h4 class="mega-col-title">Clothing</h4>
                                <a href="/Home/Shop?gender=women&cat=tops">Tops &amp; T-Shirts</a>
                                <a href="/Home/Shop?gender=women&cat=shorts">Shorts</a>
                                <a href="/Home/Shop?gender=women&cat=jackets">Jackets</a>
                                <a href="/Home/Shop?gender=women&cat=tights">Tights &amp; Leggings</a>
                            </div>
                            <div class="mega-col">
                                <h4 class="mega-col-title">Accessories</h4>
                                <a href="/Home/Shop?gender=women&cat=socks">Socks</a>
                                <a href="/Home/Shop?gender=women&cat=caps">Caps &amp; Hats</a>
                                <a href="/Home/Shop?gender=women&cat=bags">Bags</a>
                                <a href="/Home/Shop?gender=women&cat=insoles">Insoles</a>
                            </div>
                            <div class="mega-col">
                                <h4 class="mega-col-title">Sports</h4>
                                <a href="/Home/Shop?gender=women&sport=road-running">Road Running</a>
                                <a href="/Home/Shop?gender=women&sport=trail-running">Trail Running</a>
                                <a href="/Home/Shop?gender=women&sport=gym">Gym &amp; Training</a>
                                <a href="/Home/Shop?gender=women&sport=race-day">Race Day</a>
                            </div>
                        </div>
                    </div>

                    <!-- Kids -->
                    <div class="mega-item">
                        <a href="/Home/Shop?gender=kids" class="mega-link">Kids</a>
                        <div class="mega-panel">
                            <div class="mega-col">
                                <h4 class="mega-col-title">Shoes</h4>
                                <a href="/Home/Shop?gender=kids&cat=running-shoes">Running Shoes</a>
                                <a href="/Home/Shop?gender=kids&cat=trail-shoes">Trail Shoes</a>
                                <a href="/Home/Shop?gender=kids&cat=casual">Lifestyle</a>
                            </div>
                            <div class="mega-col">
                                <h4 class="mega-col-title">Clothing</h4>
                                <a href="/Home/Shop?gender=kids&cat=tops">Tops</a>
                                <a href="/Home/Shop?gender=kids&cat=shorts">Shorts</a>
                                <a href="/Home/Shop?gender=kids&cat=jackets">Jackets</a>
                            </div>
                            <div class="mega-col">
                                <h4 class="mega-col-title">Accessories</h4>
                                <a href="/Home/Shop?gender=kids&cat=socks">Socks</a>
                                <a href="/Home/Shop?gender=kids&cat=bags">Bags</a>
                                <a href="/Home/Shop?gender=kids&cat=caps">Caps</a>
                            </div>
                        </div>
                    </div>

                    <!-- Sports -->
                    <div class="mega-item">
                        <a href="/Home/Shop?sport=all" class="mega-link">Sports</a>
                        <div class="mega-panel mega-panel--slim">
                            <div class="mega-col">
                                <a href="/Home/Shop?sport=road-running">Road Running</a>
                                <a href="/Home/Shop?sport=trail-running">Trail Running</a>
                                <a href="/Home/Shop?sport=race-day">Race Day</a>
                                <a href="/Home/Shop?sport=gym">Gym &amp; Training</a>
                                <a href="/Home/Shop?sport=hiking">Hiking</a>
                                <a href="/Home/Shop?sport=walking">Walking</a>
                            </div>
                        </div>
                    </div>

                    <!-- Sale -->
                    <div class="mega-item">
                        <a href="/Home/Shop?q=sale" class="mega-link mega-link--sale">Sale</a>
                    </div>

                    <!-- New & Trending -->
                    <div class="mega-item">
                        <a href="/Home/Shop?q=new+arrivals" class="mega-link">New &amp; Trending</a>
                        <div class="mega-panel mega-panel--slim">
                            <div class="mega-col">
                                <a href="/Home/Shop?q=new+arrivals" class="mega-featured-link">New Arrivals</a>
                                <a href="/Home/Shop?q=best+sellers" class="mega-featured-link">Best Sellers</a>
                                <a href="/Home/Shop?q=trending" class="mega-featured-link">Trending Now</a>
                            </div>
                        </div>
                    </div>

                </nav>
                }

                <!-- Actions (right) -->
                <div class="header-actions">

                    <!-- Search -->
                    <div class="hdr-search-wrap" id="hdr-search-wrap">
                        <button class="hdr-search-bar" id="search-toggle-btn" onclick="openSearchOverlay()" aria-label="Search">
                            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <span>Search</span>
                        </button>
                        <div class="hdr-search-active" id="hdr-search-active">
                            <svg class="hdr-sa-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                            <input type="search" id="search-overlay-input" class="hdr-sa-input" placeholder="Search" autocomplete="off" spellcheck="false" oninput="handleSearchInput(this.value)">
                            <button class="hdr-sa-clear" onclick="clearOrCloseSearch()" aria-label="Close search">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
                            </button>
                        </div>
                    </div>

                    <!-- Cart -->
                    <a href="/Home/Cart" class="hdr-icon-btn" aria-label="Shopping Cart">
                        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
                        <span id="cart-count" class="hdr-badge">0</span>
                    </a>

                    <!-- Notification Bell -->
                    <div class="notif-wrap" id="notif-wrap">
                        <button class="hdr-icon-btn notif-btn" id="notif-btn" onclick="toggleNotifDropdown()" aria-label="Notifications">
                            <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
                            <span class="notif-dot" id="notif-dot"></span>
                        </button>
                        <div class="notif-dropdown" id="notif-dropdown">
                            <div class="notif-header">
                                <span>Notifications</span>
                                <button class="notif-clear-btn" onclick="clearNotifications()">Clear all</button>
                            </div>
                            <ul class="notif-list" id="notif-list">
                                <li class="notif-item unread">
                                    <div class="notif-icon notif-icon-order">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                                    </div>
                                    <div class="notif-body">
                                        <p class="notif-text">Your order has been confirmed!</p>
                                        <span class="notif-time">Just now</span>
                                    </div>
                                </li>
                                <li class="notif-item unread">
                                    <div class="notif-icon notif-icon-preorder">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                                    </div>
                                    <div class="notif-body">
                                        <p class="notif-text">Apex Carbon Racer 2026 pre-order opens March 2026.</p>
                                        <span class="notif-time">2 hours ago</span>
                                    </div>
                                </li>
                                <li class="notif-item">
                                    <div class="notif-icon notif-icon-promo">
                                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                                    </div>
                                    <div class="notif-body">
                                        <p class="notif-text">New arrivals just dropped — check them out!</p>
                                        <span class="notif-time">1 day ago</span>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </div>

                    <!-- Seller Dashboard -->
                    <a href="/Seller" class="hdr-icon-btn" aria-label="Seller Dashboard" title="Seller Dashboard">
                        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    </a>

                    <!-- Account / Login -->
                    <button class="hdr-icon-btn" onclick="openLoginModal()" aria-label="Account">
                        <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </button>

                </div>
            </div>
        </div>
    </header>

    <!-- ── Adidas-style Search Dropdown ────────────────── -->
    <div id="search-dropdown" class="search-dropdown" role="dialog" aria-label="Search">
        <div class="search-dropdown-panel">
            <!-- Popular chips — shown when no query -->
            <div class="search-popular-wrap" id="search-popular-wrap">
                <p class="search-popular-label">Popular Search Terms</p>
                <div class="search-chips">
                    <a href="/Home/Shop?q=running+shoes" class="search-chip">Running Shoes</a>
                    <a href="/Home/Shop?q=trail" class="search-chip">Trail</a>
                    <a href="/Home/Shop?q=carbon+racer" class="search-chip">Carbon Racer</a>
                    <a href="/Home/Shop?q=new+arrivals" class="search-chip">New Arrivals</a>
                    <a href="/Home/Shop?q=puma" class="search-chip">Puma</a>
                    <a href="/Home/Shop?q=sale" class="search-chip">Sale</a>
                    <a href="/Home/Shop?q=lightweight" class="search-chip">Lightweight</a>
                    <a href="/Home/Shop?q=basketball" class="search-chip">Basketball Shoes</a>
                </div>
            </div>
            <!-- Two-column results — shown when query exists -->
            <div class="search-results-cols" id="search-results-cols">
                <div class="search-sug-col">
                    <h3 class="search-col-title">Suggestions</h3>
                    <ul class="search-sug-list" id="search-sug-list"></ul>
                    <a class="search-see-all" id="search-see-all" href="/Home/Shop">See all &quot;&quot;</a>
                </div>
                <div class="search-prod-col">
                    <h3 class="search-col-title">Products</h3>
                    <div class="search-prod-list" id="search-prod-list"></div>
                </div>
            </div>
        </div>
        <div class="search-dropdown-backdrop" onclick="closeSearchOverlay()"></div>
    </div>

    <!-- Main Content -->
    <main class="main-content">
        @RenderBody()
    </main>

    <!-- Reviews Modal -->
    <div id="reviews-modal" class="modal" role="dialog" aria-labelledby="reviews-title" aria-modal="true">
        <div class="modal-content reviews-modal-content">
            <div class="modal-header">
                <h2 id="reviews-title">Customer Reviews</h2>
                <button class="close-btn" onclick="closeReviewsModal()" aria-label="Close reviews">&times;</button>
            </div>
            <div class="reviews-modal-body">
                <div class="reviews-grid" id="all-reviews-grid"></div>
            </div>
        </div>
    </div>

    <!-- Login Modal -->
    <div id="login-modal" class="modal" role="dialog" aria-labelledby="login-title" aria-modal="true">
        <div class="modal-content login-modal">
            <button class="modal-close-floating" onclick="closeLoginModal()" aria-label="Close">&times;</button>
            <div class="login-content">
                <h2 id="login-title">Welcome Back</h2>
                <p class="login-subtitle">Sign in to your account</p>
                <form class="login-form" onsubmit="handleLogin(event)">
                    <div class="form-group">
                        <label for="email">Email</label>
                        <input type="email" id="email" placeholder="Enter your email" autocomplete="username" required>
                    </div>
                    <div class="form-group">
                        <label for="password">Password</label>
                        <input type="password" id="password" placeholder="Enter your password" autocomplete="current-password" required>
                    </div>
                    <button type="submit" class="login-submit">Sign In</button>
                </form>
                <p class="login-footer">Don't have an account? <a href="#" onclick="toggleRegister()">Sign Up</a></p>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toast-container" class="toast-container" aria-live="polite"></div>

    <!-- Site Footer -->
    <footer class="site-footer">
        <div class="container">
            <div class="footer-grid">
                <div class="footer-brand">
                    <div class="footer-logo"><img src="/logo.png" alt="NEXT HORIZON" class="footer-logo-img"></div>
                    <p>Engineered for Performance.<br>Built for Runners.</p>
                </div>
                <div class="footer-links">
                    <h4>Shop</h4>
                    <a href="/Home/Shop">All Products</a>
                </div>
                <div class="footer-links">
                    <h4>Company</h4>
                    <a href="/Home/About">About Us</a>
                    <a href="/Home/Contact">Contact</a>
                </div>
                <div class="footer-links">
                    <h4>Support</h4>
                    <a href="/Home/Contact">Help Center</a>
                    <a href="/Home/Contact">Returns</a>
                    <a href="/Home/Contact">Shipping</a>
                </div>
            </div>
            <div class="footer-bottom">
                <p>&copy; 2026 NEXT HORIZON. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <script src="~/js/app.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <!-- Review Image Slideshow Lightbox -->
    <div class="rv-lightbox" id="rv-lightbox">
        <div class="rv-lightbox-backdrop" onclick="closeReviewSlideshow()"></div>
        <button class="rv-lightbox-close" onclick="closeReviewSlideshow()" aria-label="Close">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
        <button class="rv-slide-arrow rv-slide-prev" onclick="slideshowNav(-1)" aria-label="Previous">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="rv-lightbox-stage">
            <img class="rv-lightbox-img" id="rv-lightbox-img" src="" alt="Review photo">
        </div>
        <button class="rv-slide-arrow rv-slide-next" onclick="slideshowNav(1)" aria-label="Next">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
        <div class="rv-slide-counter" id="rv-slide-counter"></div>
    </div>
</body>
</html>
