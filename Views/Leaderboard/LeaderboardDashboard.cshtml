@{
    ViewData["Title"] = "Leaderboard Dashboard";
}

@section Styles {
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
    --gray-50:#FAFAFA; --gray-100:#F5F5F3; --gray-200:#E8E8E6;
    --gray-400:#999; --gray-600:#555; --border:rgba(0,0,0,0.08);
    --font-display:'Bebas Neue',sans-serif; --font-body:'DM Sans',sans-serif;
    --radius-md:12px; --radius-lg:18px;
}
html,body{font-family:var(--font-body);background:#fff;color:#000;overflow-x:hidden;}

/* HERO */
.hero{position:relative;min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:40px 24px 80px;background:#fff;overflow:hidden;}
.hero::before{content:'';position:absolute;inset:0;background-image:linear-gradient(rgba(0,0,0,0.04) 1px,transparent 1px),linear-gradient(90deg,rgba(0,0,0,0.04) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 80% 60% at 50% 0%,black,transparent);pointer-events:none;}
.season-label{font-size:11px;letter-spacing:4px;color:var(--gray-400);text-transform:uppercase;margin-bottom:16px;opacity:.8;position:relative;z-index:1;}
.hero-title{font-family:var(--font-display);font-size:clamp(72px,14vw,140px);line-height:.88;letter-spacing:4px;text-align:center;color:#000;margin-bottom:12px;position:relative;z-index:1;}
.hero-sub{font-size:11px;letter-spacing:6px;color:var(--gray-400);text-transform:uppercase;margin-bottom:56px;position:relative;z-index:1;}

/* PODIUM */
.podium-wrap{display:flex;align-items:flex-end;gap:12px;position:relative;z-index:2;margin-bottom:44px;}
.podium-card{display:flex;flex-direction:column;align-items:center;position:relative;}
.p-avatar-ring{position:relative;margin-bottom:-1px;z-index:2;}
.p-avatar{width:88px;height:88px;border-radius:50%;object-fit:cover;display:block;border:3px solid #fff;box-shadow:0 4px 16px rgba(0,0,0,.12);}
.p-avatar.first{width:108px;height:108px;}
.p-crown{position:absolute;top:-26px;left:50%;transform:translateX(-50%);font-size:20px;}
.p-medal{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;position:absolute;top:-12px;right:-6px;border:2px solid #fff;z-index:3;box-shadow:0 2px 8px rgba(0,0,0,.15);}
.p-medal.gold{background:#000;color:#fff;}
.p-medal.silver{background:#555;color:#fff;}
.p-medal.bronze{background:#888;color:#fff;}
.p-pillar{width:130px;border-radius:12px 12px 0 0;display:flex;flex-direction:column;align-items:center;padding:16px 8px 20px;position:relative;}
.p-pillar.first{height:200px;width:150px;background:#000;}
.p-pillar.second{height:158px;background:var(--gray-200);border:1px solid rgba(0,0,0,.1);}
.p-pillar.third{height:128px;background:var(--gray-100);border:1px solid rgba(0,0,0,.08);}
.p-rank{font-family:var(--font-display);font-size:40px;line-height:1;margin-bottom:4px;}
.p-pillar.first .p-rank{color:#fff;} .p-pillar.second .p-rank,.p-pillar.third .p-rank{color:#000;}
.p-name{font-size:9px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;text-align:center;line-height:1.3;margin-bottom:4px;}
.p-pillar.first .p-name{color:rgba(255,255,255,.85);} .p-pillar.second .p-name,.p-pillar.third .p-name{color:#000;}
.p-stat{font-size:10px;}
.p-pillar.first .p-stat{color:rgba(255,255,255,.5);} .p-pillar.second .p-stat,.p-pillar.third .p-stat{color:var(--gray-400);}

/* TOGGLES */
.toggle-row{display:flex;gap:6px;background:var(--gray-100);border:1px solid var(--border);border-radius:100px;padding:4px;position:relative;z-index:2;}
.toggle-btn{padding:8px 24px;border-radius:100px;font-size:11px;font-weight:600;letter-spacing:2px;text-transform:uppercase;cursor:pointer;border:none;transition:all .2s;color:var(--gray-600);background:transparent;font-family:var(--font-body);}
.toggle-btn.active{background:#000;color:#fff;}

/* CARD SCROLL SECTION */
.lb-section{background:#fff;padding:64px 0 0;border-top:1px solid var(--border);}
.lb-header{padding:0 40px 36px;display:flex;justify-content:space-between;align-items:flex-end;}
.lb-header-left{display:flex;flex-direction:column;gap:4px;}
.lb-eyebrow{font-size:10px;letter-spacing:5px;color:var(--gray-400);text-transform:uppercase;}
.lb-title-row{display:flex;align-items:baseline;gap:16px;}
.lb-title{font-family:var(--font-display);font-size:clamp(40px,5vw,64px);letter-spacing:3px;color:#000;line-height:1;}
.lb-view-link{font-size:10px;font-weight:700;letter-spacing:2.5px;text-transform:uppercase;color:var(--gray-600);text-decoration:none;border-bottom:1px solid rgba(0,0,0,.3);padding-bottom:1px;transition:color .2s;}
.lb-view-link:hover{color:#000;}
.lb-nav-btns{display:flex;gap:8px;}
.lb-nav{width:42px;height:42px;border-radius:50%;border:1.5px solid #000;background:#fff;color:#000;cursor:pointer;display:grid;place-items:center;font-size:16px;transition:all .2s;}
.lb-nav:hover{background:#000;color:#fff;}

.scroll-track{display:flex;gap:20px;padding:0 40px 52px;overflow-x:auto;scroll-behavior:smooth;scroll-snap-type:x mandatory;scrollbar-width:none;-webkit-overflow-scrolling:touch;}
.scroll-track::-webkit-scrollbar{display:none;}

.lb-card{flex:0 0 240px;position:relative;cursor:pointer;border-radius:var(--radius-lg);overflow:hidden;border:1px solid var(--border);background:#fff;box-shadow:0 2px 12px rgba(0,0,0,.05);scroll-snap-align:start;transition:transform .3s cubic-bezier(.22,.68,0,1.2),box-shadow .3s,border-color .3s;}
.lb-card:hover{transform:translateY(-8px);box-shadow:0 16px 40px rgba(0,0,0,.1);border-color:rgba(0,0,0,.2);}
.lb-card-img-wrap{position:relative;border-radius:10px;margin:8px 8px 0;overflow:hidden;aspect-ratio:3/4;background:var(--gray-100);}
.lb-card-img{width:100%;height:100%;object-fit:cover;display:block;filter:saturate(.75) contrast(1.05);transition:transform .4s,filter .3s;}
.lb-card:hover .lb-card-img{transform:scale(1.05);filter:saturate(1);}
.lb-card-overlay{position:absolute;inset:0;background:linear-gradient(0deg,rgba(0,0,0,.85) 0%,rgba(0,0,0,.2) 50%,transparent 100%);border-radius:inherit;}
.lb-card-rank-badge{position:absolute;top:12px;left:12px;background:rgba(0,0,0,.75);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.15);border-radius:100px;padding:4px 12px;font-family:var(--font-display);font-size:15px;letter-spacing:1px;color:#fff;z-index:2;}
.lb-card.rank-1 .lb-card-rank-badge{background:#fff;color:#000;border-color:#fff;}
.lb-card-avatar{position:absolute;bottom:52px;left:50%;transform:translateX(-50%);width:52px;height:52px;border-radius:50%;border:2px solid rgba(255,255,255,.2);object-fit:cover;z-index:3;box-shadow:0 4px 16px rgba(0,0,0,.4);}
.lb-card-info{position:absolute;bottom:0;left:0;right:0;padding:0 12px 14px;z-index:3;}
.lb-card-name{font-size:10px;font-weight:700;letter-spacing:1.5px;text-transform:uppercase;text-align:center;color:#fff;margin-bottom:2px;}
.lb-card-stat{font-size:9px;color:rgba(255,255,255,.45);text-align:center;}
.lb-card.rank-1 .lb-card-img-wrap::after{content:'';position:absolute;top:0;left:-100%;width:60%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.08),transparent);animation:shimmer 3s infinite;pointer-events:none;z-index:1;}
@@keyframes shimmer{0%{left:-100%}55%,100%{left:120%}}

/* SLIDING TABLE */
.slide-table-section{background:#fff;border-top:1px solid var(--border);}
.slide-table-outer{overflow-x:auto;scrollbar-width:thin;scrollbar-color:rgba(0,0,0,.12) transparent;-webkit-overflow-scrolling:touch;cursor:grab;}
.slide-table-outer:active{cursor:grabbing;}
.slide-table-outer::-webkit-scrollbar{height:4px;}
.slide-table-outer::-webkit-scrollbar-thumb{background:rgba(0,0,0,.12);border-radius:100px;}
.slide-table{min-width:700px;width:100%;}
.st-head{display:grid;grid-template-columns:56px 1fr 110px 110px 80px;padding:14px 40px;border-bottom:2px solid #000;font-size:9px;letter-spacing:2.5px;color:var(--gray-400);text-transform:uppercase;}
.st-row{display:grid;grid-template-columns:56px 1fr 110px 110px 80px;align-items:center;padding:14px 40px;border-bottom:1px solid var(--border);cursor:pointer;position:relative;transition:background .2s;}
.st-row:hover{background:var(--gray-50);}
.st-row.top3{background:var(--gray-50);}
.st-row.top3::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:#000;}
.st-rank{font-family:var(--font-display);font-size:24px;color:var(--gray-400);}
.st-row.top3 .st-rank{color:#000;}
.st-person{display:flex;align-items:center;gap:12px;}
.st-avatar{width:36px;height:36px;border-radius:50%;object-fit:cover;border:1px solid var(--border);}
.st-name{font-size:12px;font-weight:700;letter-spacing:.5px;text-transform:uppercase;color:#000;margin-bottom:1px;}
.st-tag{font-size:10px;color:var(--gray-400);}
.st-dist{font-size:13px;font-weight:700;color:#000;}
.st-time{font-size:12px;color:var(--gray-600);}
.st-change{font-size:11px;font-weight:700;text-align:right;}
.st-change.up{color:#000;} .st-change.same{color:var(--gray-400);} .st-change.down{color:#888;}
.st-bar-wrap{grid-column:1/-1;height:2px;background:rgba(0,0,0,.05);border-radius:1px;overflow:hidden;margin-top:8px;display:none;}
.st-row.top3 .st-bar-wrap{display:block;}
.st-bar{height:100%;background:#000;border-radius:1px;}

/* FOOTER */
.footer-section{background:#fff;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;padding:28px 40px;gap:16px;}
.footer-outline-btn{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#000;background:#fff;border:1.5px solid #000;border-radius:100px;padding:10px 28px;cursor:pointer;transition:all .2s;text-decoration:none;display:inline-block;}
.footer-outline-btn:hover{background:#000;color:#fff;}
.footer-fill-btn{font-size:10px;font-weight:700;letter-spacing:3px;text-transform:uppercase;color:#fff;background:#000;border:none;border-radius:100px;padding:10px 28px;cursor:pointer;transition:all .2s;text-decoration:none;display:inline-block;}
.footer-fill-btn:hover{background:#333;}

@@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.anim{opacity:0;animation:fadeUp .7s ease forwards;}
.d1{animation-delay:.1s} .d2{animation-delay:.25s} .d3{animation-delay:.4s} .d4{animation-delay:.55s} .d5{animation-delay:.7s}

@@media(max-width:600px){
    .lb-header,.scroll-track,.footer-section{padding-left:20px;padding-right:20px;}
    .st-head,.st-row{padding-left:20px;padding-right:20px;}
}
</style>
}

