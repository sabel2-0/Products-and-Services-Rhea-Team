@section Scripts {
<script>
function setFilter(type, btn) {
    document.querySelectorAll('.toggle-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
}

// Card scroll nav
const track = document.getElementById('cardTrack');
document.getElementById('navPrev')?.addEventListener('click', () => track.scrollBy({ left: -280, behavior: 'smooth' }));
document.getElementById('navNext')?.addEventListener('click', () => track.scrollBy({ left:  280, behavior: 'smooth' }));

// Table drag-to-scroll (mouse + touch)
const outer = document.getElementById('tableOuter');
let isDown = false, startX, scrollLeft;
outer.addEventListener('mousedown', e => { isDown = true; startX = e.pageX - outer.offsetLeft; scrollLeft = outer.scrollLeft; });
outer.addEventListener('mouseleave', () => { isDown = false; });
outer.addEventListener('mouseup', () => { isDown = false; });
outer.addEventListener('mousemove', e => {
    if (!isDown) return;
    e.preventDefault();
    const x = e.pageX - outer.offsetLeft;
    outer.scrollLeft = scrollLeft - (x - startX) * 1.5;
});
</script>
}
